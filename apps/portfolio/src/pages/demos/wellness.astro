---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Solace Wellness — Wellness Brand Demo">
  <div class="demo-page">
    <nav class="demo-nav">
      <a href="/" class="back-link">← Back to Portfolio</a>
    </nav>
    <main class="demo-content">
      <div class="demo-hero">
        <div class="kenburns"><img src="https://images.unsplash.com/photo-1545205597-3d9d02c29597?w=1200&h=600&fit=crop&q=80" alt="Solace Wellness" class="demo-hero-img" /></div>
        <div class="demo-badge">Live Demo</div>
      </div>
      <h1 class="reveal gradient-text">Solace Wellness</h1>
      <p class="demo-category">Wellness Brand</p>
      <p class="demo-description">A morning-practice aesthetic for a holistic wellness brand. Serene sage palette, editorial typography, mind-body-breath positioning.</p>
      <div class="demo-tags">
        <span>Wellness</span><span>Sage &amp; Blush</span><span>Editorial</span>
      </div>
      <a href="https://solace-wellness.pages.dev" target="_blank" rel="noopener" class="demo-cta-button">
        View live site →
      </a>
    </main>
  </div>
</BaseLayout>

<style>
  .demo-page { min-height: 100vh; background: #FBF9F7; color: #3A3533; }
  .demo-nav { padding: 2rem; }
  .back-link { color: #9DB4A0; text-decoration: none; font-size: 0.875rem; font-weight: 600; }
  .demo-content { max-width: 680px; margin: 0 auto; padding: 4rem 2rem; text-align: center; }
  .demo-hero { position: relative; margin-bottom: 2.5rem; border-radius: 12px; overflow: hidden; }
  .demo-hero-img { width: 100%; height: 280px; object-fit: cover; display: block; }
  .demo-badge { position: absolute; top: 1rem; left: 1rem; display: inline-block; padding: 0.25rem 0.75rem; background: #9DB4A0; color: #fff; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
  h1 { font-size: 2.5rem; font-weight: 400; font-style: italic; margin-bottom: 0.5rem; color: #3A3533; }
  .demo-category { color: #9DB4A0; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.5rem; }
  .demo-description { color: #8C8482; line-height: 1.6; margin-bottom: 2rem; max-width: 50ch; margin-left: auto; margin-right: auto; }
  .demo-tags { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
  .demo-tags span { padding: 0.25rem 0.75rem; border: 1px solid #E8C1C1; border-radius: 4px; font-size: 0.8125rem; color: #8C8482; }
  .demo-cta-button { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 2rem; background: #9DB4A0; color: #fff; border-radius: 8px; font-weight: 600; font-size: 0.9375rem; text-decoration: none; transition: background 0.2s, transform 0.2s; }
  .demo-cta-button:hover { background: #b5c9b5; transform: translateY(-2px); }
</style>