---
// ExperienceTimeline — horizontal scrollable journey milestones
// SVG icon set — consistent 32px stroke icons matching the calm, botanical aesthetic
const milestoneIcons = {
  sun:    `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  leaf:   `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  wind:   `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>`,
  flower: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 7.5a4.5 4.5 0 1 1 4.5 4.5M12 7.5A4.5 4.5 0 1 0 7.5 12M12 7.5V9m-4.5 3a4.5 4.5 0 1 0 4.5 4.5M7.5 12H9m7.5 0a4.5 4.5 0 1 1-4.5 4.5m4.5-4.5H15m-3 4.5V15"/><circle cx="12" cy="12" r="3"/><path d="M12 22v-3"/></svg>`,
  lotus:  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 6v4m-3-2 3 3 3-3"/></svg>`,
};

const milestones = [
  {
    time: '8:00 AM',
    title: 'Morning Stillness',
    description: 'Begin with a guided 20-minute sitting. Arrive. Breathe. Set an intention for your day.',
    icon: milestoneIcons.sun,
  },
  {
    time: '9:30 AM',
    title: 'Mindful Movement',
    description: 'A slow, somatic yoga flow to wake the body with attention and care.',
    icon: milestoneIcons.leaf,
  },
  {
    time: '11:00 AM',
    title: 'Breathwork Circle',
    description: 'Group pranayama session to regulate the nervous system and build internal warmth.',
    icon: milestoneIcons.wind,
  },
  {
    time: '1:00 PM',
    title: 'Silent Lunch',
    description: 'Eat mindfully, in silence. A practice of presence and gratitude for nourishment.',
    icon: milestoneIcons.flower,
  },
  {
    time: '3:00 PM',
    title: 'Afternoon Restoration',
    description: 'Restorative yoga and yoga nidra — deep relaxation for the nervous system.',
    icon: milestoneIcons.flower,
  },
  {
    time: '5:00 PM',
    title: 'Integration Circle',
    description: 'Share reflections from the day in a safe, confidential group setting.',
    icon: milestoneIcons.lotus,
  },
];
---

<section id="timeline" class="section section--sage">
  <div class="container">
    <div class="section__header">
      <p class="eyebrow" style="color: rgba(255,255,255,0.7);">A Day at Solace</p>
      <h2 class="reveal">The Morning Practice Experience</h2>
      <p style="color: rgba(255,255,255,0.8);">
        Every element of your day with us is intentionally designed to slow you down,
        open you up, and bring you home to your own felt experience.
      </p>
    </div>
  </div>

  <div class="timeline-wrapper mask-fade-bottom">
    <div class="timeline stagger" role="list">
      {milestones.map((step, i) => (
        <div class="timeline__item reveal" role="listitem">
          <div class="timeline__icon" aria-hidden="true">{step.icon}</div>
          <div class="timeline__connector" aria-hidden="true">
            {i < milestones.length - 1 && <span class="timeline__line"></span>}
          </div>
          <div class="timeline__card">
            <span class="timeline__time">{step.time}</span>
            <h4 class="timeline__title">{step.title}</h4>
            <p class="timeline__desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-wrapper {
    overflow-x: auto;
    padding-bottom: var(--space-6);
    padding-inline: var(--space-6);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.3) transparent;
  }

  .timeline-wrapper::-webkit-scrollbar { height: 4px; }
  .timeline-wrapper::-webkit-scrollbar-track { background: transparent; }
  .timeline-wrapper::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); border-radius: 2px; }

  .timeline {
    display: flex;
    gap: var(--space-6);
    min-width: max-content;
    max-width: 1200px;
    margin-inline: auto;
    padding-block: var(--space-4);
  }

  .timeline__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 220px;
    flex-shrink: 0;
  }

  .timeline__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-3);
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.15));
  }

  .timeline__connector {
    position: relative;
    width: 100%;
    height: 24px;
    margin-bottom: var(--space-4);
  }

  .timeline__line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1.5px;
    background: rgba(255,255,255,0.35);
    transform: translateY(-50%);
  }

  .timeline__card {
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
    width: 100%;
    transition: all 0.4s var(--ease-spring);
  }

  .timeline__card:hover {
    background: rgba(255,255,255,0.18);
    transform: translateY(-3px);
  }

  .timeline__time {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.75);
    margin-bottom: var(--space-2);
  }

  .timeline__title {
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
  }

  .timeline__desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
  }
</style>
