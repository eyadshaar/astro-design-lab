---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Meridian Security — AI Automation Agency', description = 'Enterprise-grade AI automation for security operations. Reduce alert fatigue by 89%, slash response times to 3 minutes, and eliminate 40+ hours of manual SOC work weekly.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />

  <script is:inline>
    const observer = new IntersectionObserver(e => e.forEach(el => {
      if (el.isIntersecting) {
        el.target.classList.add('is-visible');
        el.target.classList.add('visible'); // legacy alias
      }
    }), {threshold: 0.1, rootMargin: '0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>