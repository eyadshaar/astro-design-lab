---
---
<nav class="navbar">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="4" fill="#161B22"/>
        <rect x="8" y="8" width="6" height="6" fill="#3B7BF7" opacity="0.8"/>
        <rect x="18" y="8" width="6" height="6" fill="#3B7BF7" opacity="0.8"/>
        <rect x="8" y="18" width="6" height="6" fill="#3B7BF7" opacity="0.8"/>
        <rect x="18" y="18" width="6" height="6" fill="#00D4AA"/>
      </svg>
      <span class="nav-brand">Meridian Security</span>
    </a>
    <div class="nav-links">
      <a href="#problem">Problem</a>
      <a href="#systems">Systems</a>
      <a href="#process">Process</a>
      <a href="#case-studies">Results</a>
      <a href="#pricing">Pricing</a>
    </div>
    <a href="#contact" class="btn btn-primary btn-sm nav-cta">Request Demo</a>
    <button class="hamburger" id="hamburgerBtn" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div class="mobile-drawer" id="mobileDrawer">
    <nav class="mobile-nav">
      <a href="#problem" class="mobile-nav-link">Problem</a>
      <a href="#systems" class="mobile-nav-link">Systems</a>
      <a href="#process" class="mobile-nav-link">Process</a>
      <a href="#case-studies" class="mobile-nav-link">Results</a>
      <a href="#pricing" class="mobile-nav-link">Pricing</a>
      <a href="#contact" class="btn btn-primary" style="margin-top:1rem; text-align:center;">Request Demo</a>
    </nav>
  </div>
</nav>

<style>
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(13, 17, 23, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--card-border);
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  gap: 1rem;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
  flex-shrink: 0;
}
.nav-brand {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1rem;
  color: var(--text-primary);
}
.nav-links {
  display: flex;
  gap: 2rem;
}
.nav-links a {
  position: relative;
  font-size: 0.875rem;
  color: var(--text-secondary);
  text-decoration: none;
  padding: 0.4rem 0;
  transition: color 0.3s var(--ease-spring);
}
.nav-links a::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 1px;
  background: var(--blue);
  transition: width 0.4s var(--ease-spring), left 0.4s var(--ease-spring);
}
.nav-links a:hover { color: var(--text-primary); }
.nav-links a:hover::after { width: 100%; left: 0; }

.nav-cta { flex-shrink: 0; }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  flex-shrink: 0;
}
.hamburger span {
  display: block;
  width: 100%;
  height: 1.5px;
  background: var(--text-secondary);
  border-radius: 2px;
  transition: all 0.3s;
}

/* Mobile Drawer */
.mobile-drawer {
  display: none;
  flex-direction: column;
  background: var(--dark-bg);
  border-top: 1px solid var(--card-border);
  padding: 1.5rem;
}
.mobile-drawer.open { display: flex; }
.mobile-nav {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.mobile-nav-link {
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--card-border);
  transition: color 0.2s;
}
.mobile-nav-link:hover { color: var(--text-primary); }

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .hamburger { display: flex; }
}
</style>

<script>
  const btn = document.getElementById('hamburgerBtn');
  const drawer = document.getElementById('mobileDrawer');
  if (btn && drawer) {
    btn.addEventListener('click', () => {
      const isOpen = drawer.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
    drawer.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        drawer.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
