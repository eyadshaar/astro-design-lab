---
---
<section class="hero">
  <div class="container hero-grid">

    <!-- LEFT: Command + CTA -->
    <div class="hero-content stagger">
      <div class="live-badge reveal">
        <span class="live-dot"></span>
        <span class="live-label">LIVE — SOC OPERATIONS</span>
      </div>

      <h1 class="hero-headline reveal">
        Your SOC<br />
        Runs Itself.<br />
        <span class="gradient-text">You Run<br />The Business.</span>
      </h1>

      <p class="hero-desc reveal">
        Meridian AI agents autonomously handle Tier-1 alerts,
        investigate threats, and orchestrate responses — freeing your
        team for work that actually requires humans.
      </p>

      <div class="hero-actions reveal">
        <a href="#contact" class="btn btn-primary">Start Your Free Audit →</a>
        <a href="#process" class="btn btn-ghost">See How It Works →</a>
      </div>

      <div class="hero-proof reveal">
        <span class="proof-item"><strong>4 min</strong> avg response</span>
        <span class="proof-sep">·</span>
        <span class="proof-item"><strong>99.97%</strong> uptime</span>
        <span class="proof-sep">·</span>
        <span class="proof-item"><strong>0</strong> false positives</span>
      </div>
    </div>

    <!-- RIGHT: CSS SOC Dashboard Mockup -->
    <div class="hero-dashboard reveal">
      <div class="dashboard-panel">
        <div class="panel-header">
          <span class="panel-title">MERIDIAN SOC</span>
          <div class="panel-live">
            <span class="panel-dot"></span>
            <span>LIVE</span>
          </div>
        </div>

        <!-- Alert feed -->
        <div class="panel-section">
          <div class="section-label mono">THREAT FEED</div>
          <div class="alert-row">
            <span class="alert-dot alert-critical"></span>
            <span class="alert-text">Unauthorized S3 bucket access — <span class="mono">185.220.xx</span></span>
            <span class="alert-time mono">2s ago</span>
          </div>
          <div class="alert-row">
            <span class="alert-dot alert-warning"></span>
            <span class="alert-text">Failed MFA attempt — admin portal — <span class="mono">smith@...</span></span>
            <span class="alert-time mono">14s ago</span>
          </div>
          <div class="alert-row">
            <span class="alert-dot alert-resolved"></span>
            <span class="alert-text">Beacon detected — contained — <span class="mono">10.0.4.x</span></span>
            <span class="alert-time mono">1m ago</span>
          </div>
          <div class="alert-row">
            <span class="alert-dot alert-resolved"></span>
            <span class="alert-text">Port scan blocked — firewall — <span class="mono">203.0.xx</span></span>
            <span class="alert-time mono">3m ago</span>
          </div>
        </div>

        <!-- Metrics row -->
        <div class="panel-metrics">
          <div class="metric-box">
            <div class="metric-value teal mono">99.97<span class="metric-unit">%</span></div>
            <div class="metric-label">Uptime — 90d</div>
          </div>
          <div class="metric-box">
            <div class="metric-value teal mono">4<span class="metric-unit">min</span></div>
            <div class="metric-label">Avg Response</div>
          </div>
          <div class="metric-box">
            <div class="metric-value teal mono">0</div>
            <div class="metric-label">False Positives</div>
          </div>
        </div>

        <!-- Agent status grid -->
        <div class="panel-section">
          <div class="section-label mono">AGENT STATUS</div>
          <div class="agent-grid">
            <div class="agent-card">
              <span class="agent-dot agent-active"></span>
              <span class="agent-name mono">alert triage</span>
              <span class="agent-status active">ACTIVE</span>
            </div>
            <div class="agent-card">
              <span class="agent-dot agent-active"></span>
              <span class="agent-name mono">threat hunt</span>
              <span class="agent-status active">ACTIVE</span>
            </div>
            <div class="agent-card">
              <span class="agent-dot agent-standby"></span>
              <span class="agent-name mono">incident r/r</span>
              <span class="agent-status standby">STANDBY</span>
            </div>
            <div class="agent-card">
              <span class="agent-dot agent-active"></span>
              <span class="agent-name mono">compliance</span>
              <span class="agent-status active">ACTIVE</span>
            </div>
          </div>
        </div>

        <!-- Scanline overlay -->
        <div class="panel-scanlines" aria-hidden="true"></div>
      </div>
    </div>

  </div>
</section>

<style>
/* ── Hero Layout ── */
.hero {
  min-height: 100vh;
  background: var(--dark-bg);
  display: flex;
  align-items: center;
  padding: 7rem 0 4rem;
  position: relative;
  overflow: hidden;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

@media (max-width: 900px) {
  .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
  .hero-dashboard { order: -1; }
}

/* ── Live Badge ── */
.live-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(0, 212, 170, 0.08);
  border: 1px solid rgba(0, 212, 170, 0.25);
  border-radius: 100px;
  padding: 0.35rem 0.85rem;
  font-size: 0.7rem;
  font-family: var(--font-mono);
  letter-spacing: 0.1em;
  color: var(--teal);
  margin-bottom: 1.5rem;
  width: fit-content;
}

.live-dot {
  width: 6px;
  height: 6px;
  background: var(--teal);
  border-radius: 50%;
  animation: livePulse 2s ease-in-out infinite;
  box-shadow: 0 0 6px var(--teal);
}

@keyframes livePulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--teal); }
  50% { opacity: 0.35; box-shadow: 0 0 2px var(--teal); }
}

/* ── Headline ── */
.hero-headline {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 4.5vw, 3.75rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--text-primary);
  margin-bottom: 1.25rem;
  opacity: 0;
  transform: translateY(24px);
  animation: fadeUp 0.7s ease forwards 0.15s;
}

@keyframes fadeUp {
  to { opacity: 1; transform: none; }
}

/* Grid-line tech overlay */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 60px,
      rgba(255,255,255,0.025) 60px,
      rgba(255,255,255,0.025) 61px
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 60px,
      rgba(255,255,255,0.025) 60px,
      rgba(255,255,255,0.025) 61px
    );
  pointer-events: none;
  z-index: 0;
}

.hero > * { position: relative; z-index: 1; }

.teal { color: var(--teal); }

/* ── Description ── */
.hero-desc {
  font-family: var(--font-body);
  font-size: 1rem;
  line-height: 1.75;
  color: var(--text-secondary);
  max-width: 440px;
  margin-bottom: 2rem;
}

/* ── Actions ── */
.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.btn {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.4s var(--ease-spring);
  cursor: pointer;
}

.btn-primary {
  background: var(--blue);
  color: #fff;
  border: 1px solid var(--blue);
}
.btn-primary:hover { background: #2d6ae3; }

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--card-border);
}
.btn-ghost:hover { border-color: var(--teal); color: var(--teal); }

/* ── Proof Row ── */
.hero-proof {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.8rem;
  color: var(--text-secondary);
}
.hero-proof strong { color: var(--text-primary); font-weight: 600; }
.proof-sep { color: var(--text-muted); }

/* ── Dashboard Panel ── */
.hero-dashboard { display: flex; justify-content: flex-end; }

.dashboard-panel {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 8px;
  width: 100%;
  max-width: 440px;
  padding: 1.25rem;
  font-family: var(--font-body);
  position: relative;
  overflow: hidden;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--card-border);
}

.panel-title {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.12em;
}

.panel-live {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--teal);
  letter-spacing: 0.08em;
}

.panel-dot {
  width: 5px;
  height: 5px;
  background: var(--teal);
  border-radius: 50%;
  animation: livePulse 2s ease-in-out infinite;
}

.panel-section { margin-bottom: 1rem; }

.section-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.mono { font-family: var(--font-mono); }

/* ── Alert Rows ── */
.alert-row {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  padding: 0.35rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  font-size: 0.72rem;
}

.alert-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  flex-shrink: 0;
}
.alert-critical { background: #f85149; box-shadow: 0 0 4px #f85149; }
.alert-warning { background: var(--amber); }
.alert-resolved { background: var(--teal); opacity: 0.5; }

.alert-text { color: var(--text-secondary); flex: 1; }
.alert-time { color: var(--text-muted); font-size: 0.65rem; }

/* ── Metrics ── */
.panel-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  margin: 1rem 0;
}

.metric-box {
  background: rgba(0, 212, 170, 0.05);
  border: 1px solid rgba(0, 212, 170, 0.15);
  border-radius: 4px;
  padding: 0.6rem 0.5rem;
  text-align: center;
}

.metric-value {
  font-size: 1.25rem;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 0.2rem;
}
.teal { color: var(--teal); }

.metric-unit { font-size: 0.7rem; font-weight: 400; }

.metric-label {
  font-size: 0.6rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* ── Agent Grid ── */
.agent-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
}

.agent-card {
  background: var(--dark-bg);
  border: 1px solid var(--card-border);
  border-radius: 4px;
  padding: 0.5rem 0.6rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.agent-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  margin-bottom: 0.15rem;
}
.agent-active { background: var(--teal); }
.agent-standby { background: var(--text-muted); }

.agent-name {
  font-size: 0.65rem;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
}

.agent-status {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.1em;
}
.agent-status.active { color: var(--teal); }
.agent-status.standby { color: var(--text-muted); }

/* ── Scanlines Overlay ── */
.panel-scanlines {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.03) 2px,
    rgba(0, 0, 0, 0.03) 4px
  );
  pointer-events: none;
  border-radius: 8px;
}
</style>
