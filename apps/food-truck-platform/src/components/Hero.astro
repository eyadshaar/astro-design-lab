---
---
<section class="hero">
  <div class="receipt hero-receipt" style="max-width:700px; margin-bottom:2.5rem;">
    <div class="hero-accent-line"></div>
    <p class="section-label" style="text-align:center; margin-bottom:0.4rem;">★ Point of Sale Demo ★</p>
    <h1 class="hero-title reveal">Food Truck POS<br /><span class="gradient-text">Without The Chaos</span></h1>
    <p class="hero-subtitle">
      Order. Queue. Notify. All from one receipt-style screen built for the speed of the street.
    </p>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="#demo" class="btn btn-primary">See Live Demo</a>
      <a href="#customer-flow" class="btn btn-outline">How It Works</a>
    </div>
    <hr class="receipt-divider" />
    <p style="font-size:0.75rem; color:var(--muted); text-align:center;">
      Trusted by 120+ food trucks across the US
    </p>
  </div>

  <!-- Dual Operator / Customer Split -->
  <div class="hero-split stagger">
    <div class="split-card reveal">
      <p class="split-label">For Operators</p>
      <h2 class="split-title">Run Your Shift<br />Like a Pro</h2>
      <p class="split-desc">
        Real-time queue management, live order tickets, and SMS alerts — all on one dashboard that fits in your pocket.
      </p>
      <div class="split-ticket-row">
        <div class="split-ticket-dot"></div>
        <span style="font-size:0.8rem; color:var(--charcoal); font-weight:500;">Live queue board</span>
      </div>
      <div class="split-ticket-row">
        <div class="split-ticket-dot"></div>
        <span style="font-size:0.8rem; color:var(--charcoal); font-weight:500;">SMS status updates</span>
      </div>
    </div>

    <div class="split-card reveal">
      <p class="split-label" style="color:var(--orange);">For Customers</p>
      <h2 class="split-title">Order Ahead,<br />Skip The Line</h2>
      <p class="split-desc">
        Browse the menu, place your order, and get a text the moment your food is ready. No standing around.
      </p>
      <div class="split-ticket-row">
        <div class="split-ticket-dot" style="background:var(--sage);"></div>
        <span style="font-size:0.8rem; color:var(--charcoal); font-weight:500;">Order from your phone</span>
      </div>
      <div class="split-ticket-row">
        <div class="split-ticket-dot" style="background:var(--sage);"></div>
        <span style="font-size:0.8rem; color:var(--charcoal); font-weight:500;">SMS pickup notification</span>
      </div>
    </div>
  </div>
</section>
