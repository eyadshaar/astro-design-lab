---
---
<section class="sms-section">
  <div class="sms-inner">
    <div class="section-header reveal">
      <p class="section-label">No More Loitering</p>
      <h2 class="section-title">SMS Updates Keep<br /><span class="gradient-text">Them Moving</span></h2>
      <p style="max-width:480px; margin:0.75rem auto 0; font-size:0.95rem; color:var(--muted);">
        Customers hate standing in line wondering when their food will be ready. Copper Kitchen fixes that.
      </p>
    </div>

    <div class="sms-phone-mock">
      <div class="sms-phone-notch"></div>
      <div class="sms-bubble">
        <strong>Copper Kitchen</strong>
        Your order #47 is confirmed! <span class="emoji-alt">✨</span><br />Est. wait: 7 min.
      </div>
      <div class="sms-bubble">
        <strong>Copper Kitchen</strong>
        <span class="emoji-alt">🔥</span> Order #47 is being prepared!<br />Almost there...
      </div>
      <div class="sms-bubble" style="background:#FFF3E0; border-color:#FFCC80;">
        <strong>Copper Kitchen</strong>
        ✅ Order #47 is READY!<br />Pick up at the window now.
      </div>
      <div style="text-align:center; margin-top:0.5rem;">
        <span style="font-size:0.65rem; color:var(--muted);">Delivered via Twilio</span>
      </div>
    </div>

    <div class="receipt" style="max-width:440px; margin:0 auto;">
      <h3 style="font-family:var(--font-display); font-size:1rem; margin-bottom:0.75rem;">SMS Automation Rules</h3>
      <div style="display:flex; flex-direction:column; gap:0.6rem;">
        <div style="display:flex; align-items:center; gap:0.5rem;">
          <div style="width:6px;height:6px;background:var(--sage);border-radius:50%;flex-shrink:0;"></div>
          <span style="font-size:0.85rem;"><strong>On Order:</strong> "Got it! Your ticket is #47."</span>
        </div>
        <div style="display:flex; align-items:center; gap:0.5rem;">
          <div style="width:6px;height:6px;background:var(--orange);border-radius:50%;flex-shrink:0;"></div>
          <span style="font-size:0.85rem;"><strong>Cooking:</strong> "Fires are hot! #47 is being made."</span>
        </div>
        <div style="display:flex; align-items:center; gap:0.5rem;">
          <div style="width:6px;height:6px;background:var(--orange);border-radius:50%;flex-shrink:0;"></div>
          <span style="font-size:0.85rem;"><strong>Ready:</strong> "Come get it! #47 is ready."</span>
        </div>
      </div>
      <hr class="receipt-divider" />
      <p style="font-size:0.75rem; color:var(--muted); text-align:center;">
        Powered by Twilio · 99.9% deliverability
      </p>
    </div>
  </div>
</section>
