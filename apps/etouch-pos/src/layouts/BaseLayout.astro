---
import css from "../styles/global.css?inline";
interface Props { title: string; activeNav?: string; }
const { title, activeNav = "" } = Astro.props;
const nav = [
  { href: "/invoices",  label: "Invoices",  icon: "F" },
  { href: "/inventory", label: "Inventory",  icon: "E" },
  { href: "/customers", label: "Customers",  icon: "C" },
  { href: "/vendors",   label: "Vendors",   icon: "V" },
  { href: "/reports",   label: "Reports",   icon: "R" },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style set:html={css}></style>
</head>
<body>
  <div class="app-shell">
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-brand">
          <img src="/logo.jpg" alt="eTouch" style="height:36px;width:auto;border-radius:8px;object-fit:contain">
          <div class="navbar-name">
            <div>eTouch Computers</div>
            <div class="navbar-sub">Point of Sale</div>
          </div>
        </a>
        <ul class="navbar-nav">
          {nav.map(item => (
            <li>
              <a href={item.href} class={activeNav === item.href.split("/")[1] ? "active" : ""}>
                <span class="nav-icon">{item.icon}</span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
                <form method="POST" action="/api/logout" style="margin:0"><button type="submit" style="background:transparent;border:1px solid rgba(255,255,255,0.4);color:rgba(255,255,255,0.8);padding:.4rem .9rem;border-radius:8px;cursor:pointer;font-size:.8rem;font-weight:500">Logout</button></form>
              </div>
            </nav>
    <main class="main-wrap"><slot /></main>
    <footer style="text-align:center;padding:1.5rem;color:var(--muted);font-size:.78rem;border-top:1px solid var(--border);background:var(--white)">
      &copy; 2024 eTouch Computers &mdash; eTouchPOS
    </footer>
  </div>
</body>
</html>
