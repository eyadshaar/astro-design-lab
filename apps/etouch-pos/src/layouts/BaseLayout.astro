---
import css from "../styles/global.css?inline";
interface Props { title: string; activeNav?: string; }
const { title, activeNav = "" } = Astro.props;
const nav = [
  { href: "/invoices",  label: "Invoices",  icon: "F" },
  { href: "/inventory", label: "Inventory",  icon: "E" },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style set:html={css}></style>
</head>
<body>
  <div class="app-shell">
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-brand">
          <div class="navbar-logo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <div class="navbar-name">
            <div>eTouch Computers</div>
            <div class="navbar-sub">Point of Sale</div>
          </div>
        </a>
        <ul class="navbar-nav">
          {nav.map(item => (
            <li>
              <a href={item.href} class={activeNav === item.href.split("/")[1] ? "active" : ""}>
                <span class="nav-icon">{item.icon}</span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
    <main class="main-wrap"><slot /></main>
    <footer style="text-align:center;padding:1.5rem;color:var(--muted);font-size:.78rem;border-top:1px solid var(--border);background:var(--white)">
      &copy; 2024 eTouch Computers &mdash; eTouchPOS
    </footer>
  </div>
</body>
</html>
