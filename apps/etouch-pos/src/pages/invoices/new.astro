---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
let customers: any[] = [];
let products: any[] = [];
let settings: any = {};
let nextNo = "1001";
try {
  const [cr, pr, sr] = await Promise.all([
    env.DB.prepare("SELECT * FROM customers ORDER BY name").all(),
    env.DB.prepare("SELECT id, name, sell_price FROM products WHERE stock_qty > 0 ORDER BY name").all(),
    env.DB.prepare("SELECT key, value FROM settings").all(),
  ]);
  customers = cr.results || [];
  products = pr.results || [];
  for (const s of (sr.results||[])) {
    settings[s.key] = s.value;
    if (s.key === "next_invoice_no") nextNo = s.value;
  }
} catch(e) {}
const prefix = settings.invoice_prefix || "INV-";
const taxRate = parseFloat(settings.tax_rate || "6.25");
---
<BaseLayout title="New Invoice — eTouchPOS" activeNav="invoices">
  <div class="page-header"><h2>New Invoice</h2><a href="/invoices" class="btn btn-secondary">+ Back</a></div>

  <form method="POST" action="/api/invoices" id="invForm">
    <div class="card" style="margin-bottom:1.5rem">
      <div class="card-header">Invoice Details</div>
      <div class="card-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem">
          <div class="form-group">
            <label class="form-label">Invoice Number</label>
            <input class="form-control" name="invoice_no" value={prefix+nextNo} style="font-family:monospace;font-weight:700" readonly />
          </div>
          <div class="form-group">
            <label class="form-label">Customer</label>
            <select class="form-control" name="customer_id">
              <option value="">+ Walk-in Customer</option>
              {customers.map((c: any) => <option value={c.id}>{c.name}{c.phone?" ("+c.phone+")":""}</option>)}
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Line Items</label>
          <div style="border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden">
            <table class="data-table" style="margin:0">
              <thead><tr><th style="width:50%">Product</th><th class="text-right">Qty</th><th class="text-right">Unit Price</th><th class="text-right">Total</th><th style="width:40px"></th></tr></thead>
              <tbody id="lineItems">
                <tr class="line-row" data-id="0">
                  <td>
                    <select class="form-control prod-sel" name="product_id" style="margin-bottom:0">
                      <option value="">+ Select product...</option>
                      {products.map((p: any) => <option value={p.id} data-price={p.sell_price}>{p.name}</option>)}
                    </select>
                  </td>
                  <td><input class="form-control text-right qty" name="qty" type="number" value="1" min="1" style="margin-bottom:0;width:70px" /></td>
                  <td><input class="form-control text-right price" name="unit_price" type="number" step="0.01" value="0.00" style="margin-bottom:0;width:100px" /></td>
                  <td class="text-right font-bold line-total" style="padding-right:1rem">$0.00</td>
                  <td><button type="button" class="btn btn-danger btn-sm rm-btn" style="padding:.3rem .5rem">X</button></td>
                </tr>
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="5" style="padding:.75rem 1rem;background:var(--slate);border-top:1px solid var(--border)">
                    <button type="button" class="btn btn-secondary btn-sm" id="addLineBtn">+ Add Line</button>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem">
      <div>
        <div class="form-group">
          <label class="form-label">Notes</label>
          <textarea class="form-control" name="notes" rows="3" placeholder="Payment terms, thank you note..."></textarea>
        </div>
      </div>
      <div>
        <div class="form-group">
          <label class="form-label">Tax Rate (%)</label>
          <input class="form-control" id="taxRate" type="number" step="0.01" value={taxRate} oninput="recalc()" style="width:110px" />
        </div>
        <div style="background:var(--slate);border-radius:var(--radius);padding:1rem">
          <div style="display:flex;justify-content:space-between;padding:.3rem 0;font-size:.875rem"><span class="text-muted">Subtotal</span><span id="subtotalDisplay">$0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:.3rem 0;font-size:.875rem"><span class="text-muted">Tax</span><span id="taxDisplay">$0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:.6rem 0 0;border-top:2px solid var(--navy);margin-top:.5rem;font-size:1.1rem;font-weight:800;color:var(--navy)"><span>Total</span><span id="totalDisplay">$0.00</span></div>
        </div>
      </div>
    </div>

    <input type="hidden" name="items_json" id="itemsJson" />
    <div style="margin-top:1.5rem;display:flex;gap:1rem">
      <button type="submit" class="btn btn-primary btn-lg" onclick="buildJson()">Create Invoice</button>
      <a href="/invoices" class="btn btn-secondary btn-lg">Cancel</a>
    </div>
  </form>

<script>
function fmt(n) { return "$"+Number(n||0).toFixed(2); }
function recalc() {
  let sub = 0;
  document.querySelectorAll(".line-row").forEach(row => {
    const q = parseFloat(row.querySelector(".qty")?.value) || 0;
    const p = parseFloat(row.querySelector(".price")?.value) || 0;
    row.querySelector(".line-total").textContent = fmt(q*p);
    sub += q*p;
  });
  const tax = sub * (parseFloat(document.getElementById("taxRate")?.value||0) / 100);
  document.getElementById("subtotalDisplay").textContent = fmt(sub);
  document.getElementById("taxDisplay").textContent = fmt(tax);
  document.getElementById("totalDisplay").textContent = fmt(sub+tax);
}
function addLine() {
  const tbody = document.getElementById("lineItems");
  const firstRow = tbody.querySelector(".line-row");
  const clone = firstRow.cloneNode(true);
  clone.querySelectorAll("input").forEach(i => i.value = i.classList.contains("qty") ? "1" : "0.00");
  const sel = clone.querySelector("select");
  sel.selectedIndex = 0;
  clone.querySelector(".line-total").textContent = "$0.00";
  tbody.appendChild(clone);
  attachRowEvents(clone);
}
function attachRowEvents(row) {
  row.querySelectorAll("input").forEach(i => i.addEventListener("input", recalc));
  row.querySelector(".prod-sel")?.addEventListener("change", function() {
    const opt = this.selectedOptions[0];
    if (opt && opt.dataset.price) {
      row.querySelector(".price").value = parseFloat(opt.dataset.price).toFixed(2);
    }
    recalc();
  });
  row.querySelector(".rm-btn")?.addEventListener("click", function() {
    if (document.querySelectorAll(".line-row").length > 1) { row.remove(); recalc(); }
  });
}
function buildJson() {
  const items = [];
  document.querySelectorAll(".line-row").forEach(row => {
    const sel = row.querySelector(".prod-sel");
    const desc = sel?.selectedOptions[0]?.text?.trim() || "";
    const q = parseFloat(row.querySelector(".qty")?.value) || 1;
    const p = parseFloat(row.querySelector(".price")?.value) || 0;
    if (p > 0) items.push({ description: desc, qty: q, unit_price: p, total: q*p });
  });
  document.getElementById("itemsJson").value = JSON.stringify(items);
}
document.getElementById("addLineBtn")?.addEventListener("click", addLine);
document.querySelectorAll(".line-row").forEach(row => attachRowEvents(row));
recalc();
</script>
</BaseLayout>
