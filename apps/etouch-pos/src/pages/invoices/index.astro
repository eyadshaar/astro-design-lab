---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
let invoices: any[] = [];
let settings: any = {};
try {
  const [r, s] = await Promise.all([
    env.DB.prepare("SELECT i.*, c.name FROM invoices i LEFT JOIN customers c ON i.customer_id=c.id ORDER BY i.created_at DESC LIMIT 100").all(),
    env.DB.prepare("SELECT key, value FROM settings").all(),
  ]);
  invoices = r.results || [];
  for (const x of (s.results||[])) settings[x.key] = x.value;
} catch(e) {}
const sf = new URL(Astro.request.url).searchParams.get("status") || "";
const filtered = invoices.filter((i: any) => !sf || i.status === sf);
const counts: any = { draft:0, sent:0, paid:0, cancelled:0 };
for (const i of invoices) { if (i.status in counts) counts[i.status]++; }
const totalRev = invoices.filter((i: any)=>i.status==="paid").reduce((s:number,i:any)=>s+i.total,0);
const fmt = (n: number) => "$"+Number(n||0).toFixed(2);
const fmtD = (ts: number) => ts ? new Date(ts*1000).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}) : "—";
const pill: Record<string,string> = { draft:"pill-draft", sent:"pill-sent", paid:"pill-paid", cancelled:"pill-cancelled" };
---
<BaseLayout title="Invoices — eTouchPOS" activeNav="invoices">
  <div class="page-header"><h2>Invoices</h2><a href="/invoices/new" class="btn btn-primary">+ New Invoice</a></div>
  <div class="stats-row" style="margin-bottom:1.25rem">
    <div class="stat-card"><div class="stat-label">Total Revenue</div><div class="stat-value">{fmt(totalRev)}</div></div>
    <div class="stat-card"><div class="stat-label">All Invoices</div><div class="stat-value">{invoices.length}</div></div>
    <div class="stat-card"><div class="stat-label">Paid</div><div class="stat-value" style="color:var(--success)">{counts.paid}</div></div>
    <div class="stat-card"><div class="stat-label">Outstanding</div><div class="stat-value" style="color:var(--warning)">{counts.sent||0}</div></div>
  </div>
  <div class="status-tabs">
    <a href="/invoices" class={"tab-btn"+(sf===""?" active":"")}>All ({invoices.length})</a>
    <a href="/invoices?status=draft" class={"tab-btn"+(sf==="draft"?" active":"")}>Draft ({counts.draft||0})</a>
    <a href="/invoices?status=sent" class={"tab-btn"+(sf==="sent"?" active":"")}>Sent ({counts.sent||0})</a>
    <a href="/invoices?status=paid" class={"tab-btn"+(sf==="paid"?" active":"")}>Paid ({counts.paid||0})</a>
    <a href="/invoices?status=cancelled" class={"tab-btn"+(sf==="cancelled"?" active":"")}>Cancelled ({counts.cancelled||0})</a>
  </div>
  <div class="card">
    {filtered.length === 0 ? (
      <div class="card-body"><div class="empty-state"><div class="empty-icon">F</div><div style="font-weight:700;margin-bottom:.5rem">No invoices yet</div><div style="margin-bottom:1rem">Create your first invoice</div><a href="/invoices/new" class="btn btn-primary">+ Create Invoice</a></div></div>
    ) : (
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead><tr><th>Invoice #</th><th>Customer</th><th class="text-right">Subtotal</th><th class="text-right">Tax</th><th class="text-right">Total</th><th>Status</th><th>Date</th><th></th></tr></thead>
          <tbody>
            {filtered.map((inv: any) => (
              <tr>
                <td><a href={"/invoices/"+inv.id} style="font-weight:700;color:var(--navy);font-family:monospace">{inv.invoice_no}</a></td>
                <td>{inv.name||"—"}</td>
                <td class="text-right">{fmt(inv.subtotal)}</td>
                <td class="text-right text-muted">{fmt(inv.tax_amount)}</td>
                <td class="text-right font-bold">{fmt(inv.total)}</td>
                <td><span class={"status-pill "+pill[inv.status]||"pill-draft"}>{inv.status}</span></td>
                <td class="text-muted" style="font-size:.82rem">{fmtD(inv.created_at)}</td>
                <td><a href={"/invoices/"+inv.id} class="btn btn-secondary btn-sm">View</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</BaseLayout>
