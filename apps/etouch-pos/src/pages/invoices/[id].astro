---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
const id = new URL(Astro.request.url).pathname.split("/").pop();
let invoice: any = null;
let items: any[] = [];
let settings: any = {};
try {
  const inv = await env.DB.prepare("SELECT i.*, c.name as cn, c.phone as cp, c.email as ce FROM invoices i LEFT JOIN customers c ON i.customer_id=c.id WHERE i.id=?").bind(id).first();
  invoice = inv;
  if (invoice) {
    const it = await env.DB.prepare("SELECT * FROM invoice_items WHERE invoice_id=?").bind(id).all();
    items = it.results || [];
  }
  const sr = await env.DB.prepare("SELECT key, value FROM settings").all();
  for (const s of (sr.results||[])) settings[s.key] = s.value;
} catch(e) {}
if (!invoice) return Astro.redirect("/invoices");
const shopName = settings.shop_name||"eTouch Computers";
const fmt = (n: number) => "$"+Number(n||0).toFixed(2);
const fmtD = (ts: number) => ts ? new Date(ts*1000).toLocaleDateString("en-US",{month:"long",day:"numeric",year:"numeric"}) : "—";
const pill: Record<string,string> = { draft:"pill-draft", sent:"pill-sent", paid:"pill-paid", cancelled:"pill-cancelled" };
const taxRate = parseFloat(settings.tax_rate||"6.25");
const updated = Astro.request.url.includes("updated=1");
---
<BaseLayout title={"Invoice "+invoice.invoice_no+" — eTouchPOS"} activeNav="invoices">
  {updated && <div class="alert alert-success">Invoice updated!</div>}
  <div class="page-header">
    <h2>Invoice <span style="font-family:monospace;font-size:1.2rem">{invoice.invoice_no}</span></h2>
    <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap">
      <span class={"status-pill "+pill[invoice.status]} style="font-size:.875rem;padding:.5rem 1rem">{invoice.status.toUpperCase()}</span>
      <button onclick="window.print()" class="btn btn-secondary no-print">Print</button>
    </div>
  </div>

  <div class="invoice-view">
    <div class="card" style="margin-bottom:1.5rem">
      <div class="card-body">
        <div class="invoice-header-grid">
          <div>
            <div class="invoice-shop-name">{shopName}</div>
            <div class="text-muted" style="font-size:.875rem;margin-bottom:.75rem">{settings.shop_address||""}</div>
            <div class="text-muted" style="font-size:.875rem">{settings.shop_phone||""} | {settings.shop_email||""}</div>
          </div>
          <div>
            <table class="invoice-meta-table">
              <tr><td>Invoice No.</td><td style="font-family:monospace;font-weight:700">{invoice.invoice_no}</td></tr>
              <tr><td>Date</td><td>{fmtD(invoice.created_at)}</td></tr>
              {invoice.due_date ? <tr><td>Due</td><td>{fmtD(invoice.due_date)}</td></tr> : null}
              <tr><td>Customer</td><td>{invoice.cn || "Walk-in Customer"}</td></tr>
              {invoice.cp ? <tr><td>Phone</td><td>{invoice.cp}</td></tr> : null}
              {invoice.ce ? <tr><td>Email</td><td>{invoice.ce}</td></tr> : null}
            </table>
            {invoice.status === "draft" && (
              <form method="POST" action={"/api/invoices?action=status&id="+invoice.id} style="margin-top:1rem">
                <input type="hidden" name="status" value="sent" />
                <button type="submit" class="btn btn-primary btn-sm">Mark as Sent</button>
              </form>
            )}
            {invoice.status === "sent" && (
              <form method="POST" action={"/api/invoices?action=status&id="+invoice.id} style="margin-top:1rem">
                <input type="hidden" name="status" value="paid" />
                <button type="submit" class="btn btn-success btn-sm">Mark as Paid</button>
              </form>
            )}
          </div>
        </div>

        <table class="data-table">
          <thead><tr><th>Description</th><th class="text-right">Qty</th><th class="text-right">Unit Price</th><th class="text-right">Total</th></tr></thead>
          <tbody>
            {items.map((item: any) => (
              <tr>
                <td>{item.description}</td>
                <td class="text-right">{item.qty}</td>
                <td class="text-right">{fmt(item.unit_price)}</td>
                <td class="text-right font-bold">{fmt(item.total)}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="invoice-totals">
          <div class="invoice-total-row"><span class="text-muted">Subtotal</span><span>{fmt(invoice.subtotal)}</span></div>
          <div class="invoice-total-row"><span class="text-muted">Tax ({taxRate.toFixed(2)}%)</span><span>{fmt(invoice.tax_amount)}</span></div>
          <div class="invoice-total-row final"><span>Total</span><span>{fmt(invoice.total)}</span></div>
        </div>

        {invoice.notes && (
          <div style="margin-top:2rem;padding-top:1rem;border-top:1px solid var(--border)">
            <div style="font-size:.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.4rem">Notes</div>
            <div style="font-size:.9rem">{invoice.notes}</div>
          </div>
        )}
      </div>
    </div>

    <div class="no-print" style="display:flex;gap:1rem">
      <a href={"/invoices?status="+invoice.status} class="btn btn-secondary">+ Back</a>
      {invoice.status !== "paid" && invoice.status !== "cancelled" && (
        <form method="POST" action={"/api/invoices?action=status&id="+invoice.id} onsubmit="return confirm('Cancel this invoice?')">
          <input type="hidden" name="status" value="cancelled" />
          <button type="submit" class="btn btn-danger">Cancel Invoice</button>
        </form>
      )}
    </div>
  </div>
</BaseLayout>
