---
import BaseLayout from "../../layouts/BaseLayout.astro";
const db = (Astro.locals as any).runtime?.env?.DB;
const id = new URL(Astro.request.url).pathname.split("/").pop();
let vendor: any = null;
try {
  vendor = await db.prepare("SELECT * FROM vendors WHERE id=?").bind(id).first();
} catch(e) {}
if (!vendor) return Astro.redirect("/vendors");
const fmtD = (ts: number) => ts ? new Date(ts*1000).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}) : "—";
const error = new URL(Astro.request.url).searchParams.get("error") || "";
---
<BaseLayout title={"Edit "+vendor.name+" — eTouchPOS"} activeNav="vendors">
  {error && <div class="alert alert-danger">{error.replace(/\+/g," ")}</div>}
  <div class="page-header">
    <h2>{vendor.name}</h2>
    <div style="display:flex;gap:.75rem">
      <a href="/vendors" class="btn btn-secondary">+ Back</a>
      <form method="POST" action={"/api/vendors?action=delete&id="+vendor.id} onsubmit="return confirm('Delete this vendor? Cannot be undone.')">
        <button type="submit" class="btn btn-danger">Delete</button>
      </form>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start">
    <div>
      <div class="card" style="margin-bottom:1.5rem">
        <div class="card-header">Edit Vendor</div>
        <div class="card-body">
          <form method="POST" action={"/api/vendors?action=update&id="+vendor.id}>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem">
              <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">Vendor Name *</label>
                <input class="form-control" name="name" value={vendor.name||""} required />
              </div>
              <div class="form-group">
                <label class="form-label">Contact Person</label>
                <input class="form-control" name="contact_person" value={vendor.contact_person||""} />
              </div>
              <div class="form-group">
                <label class="form-label">Phone</label>
                <input class="form-control" name="phone" type="tel" value={vendor.phone||""} />
              </div>
              <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-control" name="email" type="email" value={vendor.email||""} />
              </div>
              <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">Address</label>
                <textarea class="form-control" name="address" rows="2">{vendor.address||""}</textarea>
              </div>
              <div class="form-group" style="grid-column:1/-1">
                <label class="form-label">Notes</label>
                <textarea class="form-control" name="notes" rows="3">{vendor.notes||""}</textarea>
              </div>
            </div>
            <div style="margin-top:1.5rem">
              <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div>
      <div class="card">
        <div class="card-header">Contact Details</div>
        <div class="card-body">
          <div style="margin-bottom:1.25rem">
            <div class="stat-label">Contact Person</div>
            <div style="font-size:1rem;font-weight:600">{vendor.contact_person||"—"}</div>
          </div>
          <div style="margin-bottom:1.25rem">
            <div class="stat-label">Phone</div>
            <div style="font-size:1rem;font-weight:600">{vendor.phone||"—"}</div>
          </div>
          <div style="margin-bottom:1.25rem">
            <div class="stat-label">Email</div>
            <div style="font-size:1rem;font-weight:600">{vendor.email||"—"}</div>
          </div>
          <div style="margin-bottom:1.25rem">
            <div class="stat-label">Address</div>
            <div style="font-size:.9rem;color:var(--muted);line-height:1.5">{vendor.address||"—"}</div>
          </div>
          <div style="border-top:1px solid var(--border);padding-top:1rem;margin-top:.5rem">
            <div class="stat-label">Added</div>
            <div style="font-size:1rem;font-weight:600">{fmtD(vendor.created_at)}</div>
          </div>
        </div>
      </div>
      {vendor.notes && (
        <div class="card" style="margin-top:1.25rem">
          <div class="card-header">Notes</div>
          <div class="card-body">
            <div style="font-size:.9rem;color:var(--muted);line-height:1.5;white-space:pre-wrap">{vendor.notes}</div>
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
