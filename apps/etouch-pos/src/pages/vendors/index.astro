---
import BaseLayout from "../../layouts/BaseLayout.astro";
const db = (Astro.locals as any).runtime?.env?.DB;
let vendors: any[] = [];
try {
  const r = await db.prepare("SELECT * FROM vendors ORDER BY name").all();
  vendors = r.results || [];
} catch(e) {}
const sf = new URL(Astro.request.url).searchParams.get("search") || "";
const filtered = vendors.filter((v: any) => {
  if (!sf) return true;
  const s = sf.toLowerCase();
  return (v.name||"").toLowerCase().includes(s) || (v.contact_person||"").toLowerCase().includes(s) || (v.phone||"").includes(s) || (v.email||"").toLowerCase().includes(s);
});
const created = Astro.request.url.includes("created=1");
const updated = Astro.request.url.includes("updated=1");
const deleted = Astro.request.url.includes("deleted=1");
const fmtD = (ts: number) => ts ? new Date(ts*1000).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}) : "—";
---
<BaseLayout title="Vendors — eTouchPOS" activeNav="vendors">
  {created && <div class="alert alert-success">Vendor added!</div>}
  {updated && <div class="alert alert-success">Vendor updated!</div>}
  {deleted && <div class="alert alert-success">Vendor deleted.</div>}
  <div class="page-header"><h2>Vendors</h2><a href="/vendors/new" class="btn btn-primary">+ Add Vendor</a></div>
  <div class="stats-row">
    <div class="stat-card"><div class="stat-label">Total Vendors</div><div class="stat-value">{vendors.length}</div></div>
    <div class="stat-card"><div class="stat-label">Showing</div><div class="stat-value">{filtered.length}{filtered.length!==vendors.length?" of "+vendors.length:""}</div></div>
  </div>
  <div class="card">
    <div class="card-header">
      <span>{filtered.length} vendor{filtered.length!==1?"s":""}</span>
      <form method="GET" class="flex gap-1 align-center">
        <input class="form-control" name="search" value={sf} placeholder="Search name, contact, phone, email..." style="max-width:260px;height:34px;padding:0 .75rem" />
        <button type="submit" class="btn btn-secondary btn-sm">Search</button>
        {sf && <a href="/vendors" class="btn btn-secondary btn-sm">Clear</a>}
      </form>
    </div>
    {filtered.length === 0 ? (
      <div class="card-body"><div class="empty-state"><div class="empty-icon">V</div><div style="font-weight:700;margin-bottom:.5rem">{vendors.length===0?"No vendors yet":"No matches"}</div><div style="margin-bottom:1rem">{vendors.length===0?"Add your first vendor to get started":"Try different search terms"}</div>{vendors.length===0 ? <a href="/vendors/new" class="btn btn-primary">+ Add First Vendor</a> : <a href="/vendors" class="btn btn-secondary">Clear Search</a>}</div></div>
    ) : (
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead><tr><th>Name</th><th>Contact Person</th><th>Phone</th><th>Email</th><th>Added</th><th></th></tr></thead>
          <tbody>
            {filtered.map((v: any) => (
              <tr>
                <td><a href={"/vendors/"+v.id} style="font-weight:600;color:var(--navy);text-decoration:none">{v.name}</a></td>
                <td class="text-muted">{v.contact_person||"—"}</td>
                <td class="text-muted">{v.phone||"—"}</td>
                <td class="text-muted">{v.email||"—"}</td>
                <td class="text-muted" style="font-size:.82rem">{fmtD(v.created_at)}</td>
                <td><a href={"/vendors/"+v.id} class="btn btn-secondary btn-sm">Edit</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</BaseLayout>
