---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
let categories: any[] = [];
try { categories = (await env.DB.prepare("SELECT * FROM categories ORDER BY name").all()).results || []; } catch(e) {}
---
<BaseLayout title="Add Product" activeNav="inventory">
  <div class="page-header"><h2>Add Product</h2><a href="/inventory" class="btn btn-secondary">Cancel</a></div>
  <form method="POST" action="/api/inventory">
    <input type="hidden" name="action" value="create" />
    <div class="card">
      <div class="card-header">Product Details</div>
      <div class="card-body">
        <div class="form-row">
          <div class="form-group"><label class="form-label">Product Name *</label><input class="form-control" name="name" required placeholder="e.g. NVIDIA RTX 4080 Super" /></div>
          <div class="form-group"><label class="form-label">SKU / Barcode</label><input class="form-control" name="sku" placeholder="e.g. RTX4080SUP-01" /></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Category</label><select class="form-control" name="category_id"><option value="">— Select —</option>{categories.map((c: any) => <option value={c.id}>{c.name}</option>)}</select></div>
          <div class="form-group"><label class="form-label">Description</label><input class="form-control" name="description" placeholder="Optional notes" /></div>
        </div>
        <div class="form-row form-row-3">
          <div class="form-group"><label class="form-label">Cost Price ($)</label><input class="form-control" name="cost_price" type="number" step="0.01" min="0" /></div>
          <div class="form-group"><label class="form-label">Sell Price ($)</label><input class="form-control" name="sell_price" type="number" step="0.01" min="0" /></div>
          <div class="form-group"><label class="form-label">Initial Stock</label><input class="form-control" name="stock_qty" type="number" min="0" value="0" /></div>
        </div>
        <div class="form-group"><label class="form-label">Low Stock Threshold</label><input class="form-control" name="low_stock_threshold" type="number" min="0" value="5" style="max-width:120px" /><small style="color:var(--text-muted);font-size:0.8rem"> Alert when stock falls to or below this</small></div>
      </div>
    </div>
    <div class="mt-2"><button type="submit" class="btn btn-primary">Add Product</button></div>
  </form>
</BaseLayout>
