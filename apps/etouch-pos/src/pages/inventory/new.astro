---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
let categories: any[] = [];
try {
  const cr = await env.DB.prepare("SELECT * FROM categories ORDER BY name").all();
  categories = cr.results || [];
} catch(e) {}
---
<BaseLayout title="Add Product — eTouchPOS" activeNav="inventory">
  <div class="page-header"><h2>Add Product</h2><a href="/inventory" class="btn btn-secondary">+ Back</a></div>
  <div style="max-width:720px">
    <div class="card">
      <div class="card-header">Product Information</div>
      <div class="card-body">
        <form method="POST" action="/api/inventory">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem">
            <div class="form-group" style="grid-column:1/-1">
              <label class="form-label">Product Name *</label>
              <input class="form-control" name="name" required placeholder="e.g. NVIDIA RTX 4080 Super 16GB" />
            </div>
            <div class="form-group">
              <label class="form-label">SKU / Barcode</label>
              <input class="form-control" name="sku" placeholder="Optional" />
            </div>
            <div class="form-group">
              <label class="form-label">Category</label>
              <select class="form-control" name="category_id">
                <option value="">+ Select category...</option>
                {categories.map((c: any) => <option value={c.id}>{c.name}</option>)}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Cost Price ($) *</label>
              <input class="form-control" name="cost_price" type="number" step="0.01" min="0" required placeholder="0.00" />
            </div>
            <div class="form-group">
              <label class="form-label">Sell Price ($) *</label>
              <input class="form-control" name="sell_price" type="number" step="0.01" min="0" required placeholder="0.00" oninput="updateMargin()" />
            </div>
            <div class="form-group" id="marginDisplay" style="display:flex;align-items:flex-end;padding-bottom:.6rem;font-weight:700;color:var(--muted);font-size:.85rem">
              Margin: --
            </div>
            <div class="form-group">
              <label class="form-label">Stock Quantity *</label>
              <input class="form-control" name="stock_qty" type="number" min="0" value="0" required />
            </div>
            <div class="form-group">
              <label class="form-label">Low Stock Alert Threshold</label>
              <input class="form-control" name="low_stock_threshold" type="number" min="0" value="5" />
              <div class="form-hint">Alert when stock falls below this</div>
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label class="form-label">Description</label>
              <textarea class="form-control" name="description" rows="2" placeholder="Optional notes..."></textarea>
            </div>
          </div>
          <div style="margin-top:1.5rem;display:flex;gap:1rem">
            <button type="submit" class="btn btn-primary btn-lg">+ Add Product</button>
            <a href="/inventory" class="btn btn-secondary btn-lg">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
<script>
function updateMargin() {
  const cost = parseFloat(document.querySelector('[name="cost_price"]')?.value) || 0;
  const sell = parseFloat(document.querySelector('[name="sell_price"]')?.value) || 0;
  const el = document.getElementById("marginDisplay");
  if (sell > 0 && cost > 0) {
    const m = ((sell - cost) / sell * 100).toFixed(1);
    el.textContent = "Margin: " + m + "%";
    el.style.color = m < 10 ? "var(--danger)" : "var(--success)";
  } else {
    el.textContent = "Margin: --";
    el.style.color = "var(--muted)";
  }
}
document.querySelector('[name="sell_price"]')?.addEventListener("input", updateMargin);
document.querySelector('[name="cost_price"]')?.addEventListener("input", updateMargin);
</script>
</BaseLayout>
