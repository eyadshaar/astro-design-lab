---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database }; params: { id: string } }
const { env, params } = Astro.props;
const id = parseInt(params.id);
let product: any = null; let categories: any[] = []; let stockLog: any[] = [];
try {
  const [p, c, l] = await Promise.all([
    env.DB.prepare("SELECT * FROM products WHERE id=?").bind(id).first(),
    env.DB.prepare("SELECT * FROM categories ORDER BY name").all(),
    env.DB.prepare("SELECT * FROM stock_log WHERE product_id=? ORDER BY created_at DESC LIMIT 20").bind(id).all(),
  ]);
  product = p; categories = c.results||[]; stockLog = l.results||[];
} catch(e) {}
if (!product) return Astro.redirect("/inventory");
const fmtDate = (ts: number) => new Date(ts*1000).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric",hour:"2-digit",minute:"2-digit"});
const fmt = (n: number) => "$"+Number(n||0).toFixed(2);
const margin = product.sell_price>0 ? ((product.sell_price-product.cost_price)/product.sell_price*100) : 0;
const isLow = (product.stock_qty||0) <= (product.low_stock_threshold||5);
const deleted = new URL(Astro.request.url).searchParams.get("deleted") === "1";
---
<BaseLayout title={"Edit: "+product.name} activeNav="inventory">
  {deleted && <div style="background:#d1fae5;color:#065f46;padding:0.75rem 1rem;border-radius:8px;margin-bottom:1rem;font-weight:600">Product deleted. <a href="/inventory" style="color:#065f46;text-decoration:underline">Back to inventory</a></div>}
  <div class="page-header"><h2>{product.name}</h2><a href="/inventory" class="btn btn-secondary">Back</a></div>
  <div style="display:grid;grid-template-columns:1fr 320px;gap:1rem;align-items:start">
    <div>
      <form method="POST" action={"/api/inventory?id="+id}>
        <input type="hidden" name="action" value="update" />
        <div class="card mb-2"><div class="card-header">Edit Product</div><div class="card-body">
          <div class="form-row"><div class="form-group"><label class="form-label">Product Name *</label><input class="form-control" name="name" value={product.name} required /></div><div class="form-group"><label class="form-label">SKU</label><input class="form-control" name="sku" value={product.sku||""} /></div></div>
          <div class="form-row"><div class="form-group"><label class="form-label">Category</label><select class="form-control" name="category_id"><option value="">— None —</option>{categories.map((c:any) => <option value={c.id} selected={product.category_id==c.id}>{c.name}</option>)}</select></div><div class="form-group"><label class="form-label">Description</label><input class="form-control" name="description" value={product.description||""} /></div></div>
          <div class="form-row form-row-3"><div class="form-group"><label class="form-label">Cost Price ($)</label><input class="form-control" name="cost_price" type="number" step="0.01" min="0" value={product.cost_price} /></div><div class="form-group"><label class="form-label">Sell Price ($)</label><input class="form-control" name="sell_price" type="number" step="0.01" min="0" value={product.sell_price} /></div><div class="form-group"><label class="form-label">Margin</label><div style="padding:0.6rem 0.85rem;background:var(--silver);border-radius:6px;font-weight:700;color:var(--navy)">{margin.toFixed(1)}%</div></div></div>
          <div class="form-group"><label class="form-label">Low Stock Threshold</label><input class="form-control" name="low_stock_threshold" type="number" min="0" value={product.low_stock_threshold||5} style="max-width:120px" /></div>
        </div></div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </form>
      <div class="card mt-2"><div class="card-header">Adjust Stock</div><div class="card-body">
        <div style="margin-bottom:1rem"><div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);font-weight:600">Current Stock</div><div style="font-size:2rem;font-weight:700;color:var(--navy)">{product.stock_qty} <span class={"badge "+(isLow?"badge-low":"badge-ok")} style="font-size:0.7rem">{isLow?"LOW":"OK"}</span></div></div>
        <form method="POST" action={"/api/inventory?id="+id} class="flex gap-1 align-center">
          <input type="hidden" name="action" value="adjust_stock" />
          <div class="form-group" style="margin-bottom:0"><label class="form-label">Delta (+/-)</label><input class="form-control" name="delta" type="number" value="0" style="max-width:100px" /></div>
          <div class="form-group" style="margin-bottom:0;flex:1"><label class="form-label">Reason</label><input class="form-control" name="reason" placeholder="New shipment, return..." /></div>
          <button type="submit" class="btn btn-primary" style="margin-bottom:0">Apply</button>
        </form>
      </div></div>
    </div>
    <div>
      <div class="card"><div class="card-header">Stock History</div><div class="card-body" style="padding:0">
        {stockLog.length === 0 ? <div class="empty-state" style="padding:2rem">No history yet.</div> : (
          <table class="data-table"><thead><tr><th>Date</th><th class="text-right">Delta</th><th>Reason</th></tr></thead><tbody>
            {stockLog.map((log:any) => (<tr><td style="font-size:0.75rem;color:var(--text-muted)">{fmtDate(log.created_at)}</td><td class={"text-right font-bold "+(log.delta>=0?"text-success":"text-danger")}>{log.delta>0?"+":""}{log.delta}</td><td style="font-size:0.8rem;color:var(--text-muted)">{log.reason||"—"}</td></tr>))}
          </tbody></table>
        )}
      </div></div>
    </div>
  </div>
  <div class="card mt-2" style="border:1px solid var(--danger)"><div class="card-header" style="background:var(--danger)">Danger Zone</div><div class="card-body">
    <form method="POST" action={"/api/inventory?id="+id} onsubmit="return confirm('Delete this product? Cannot be undone.')">
      <input type="hidden" name="action" value="delete" />
      <div class="flex-between"><div><div style="font-weight:600">Delete Product</div><div style="font-size:0.85rem;color:var(--text-muted)">Permanently remove this product.</div></div><button type="submit" class="btn btn-danger">Delete</button></div>
    </form>
  </div></div>
</BaseLayout>
