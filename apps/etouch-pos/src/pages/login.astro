---
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
const url = new URL(Astro.request.url);
const error = url.searchParams.get("error");
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — eTouchPOS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body style="background:linear-gradient(135deg,#1B3A6B 0%,#2A5298 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:Inter,sans-serif;margin:0">
  <div style="background:white;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,0.3);padding:3rem;width:100%;max-width:420px;margin:1rem">
    <div style="text-align:center;margin-bottom:2rem">
      <div style="background:linear-gradient(135deg,#1B3A6B,#2A5298);border-radius:14px;width:64px;height:64px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
      </div>
      <h1 style="color:#1B3A6B;font-size:1.5rem;font-weight:800;margin:0 0 .25rem">eTouchPOS</h1>
      <p style="color:#64748b;font-size:.9rem;margin:0">Enter your password to continue</p>
    </div>
    {error && (
      <div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;border-radius:10px;padding:.85rem 1rem;margin-bottom:1rem;font-size:.9rem">
        Incorrect password. Try again.
      </div>
    )}
    <form method="POST" action="/api/login">
      <div style="margin-bottom:1.25rem">
        <label style="display:block;font-weight:600;color:#334155;font-size:.85rem;margin-bottom:.5rem">Password</label>
        <input
          type="password"
          name="password"
          required
          autofocus
          placeholder="Enter your password"
          style="width:100%;padding:.85rem 1rem;border:2px solid #e2e8f0;border-radius:10px;font-size:1rem;font-family:Inter;outline:none;transition:border-color .2s;box-sizing:border-box"
          onfocus="this.style.borderColor='#1B3A6B'"
          onblur="this.style.borderColor='#e2e8f0'"
        />
      </div>
      <button
        type="submit"
        style="width:100%;padding:.9rem;background:linear-gradient(135deg,#1B3A6B,#2A5298);color:white;border:none;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer"
      >
        Sign In
      </button>
    </form>
  </div>
</body>
</html>
