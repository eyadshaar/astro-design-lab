---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { D1Database } from "@cloudflare/workers-types";
interface Props { env: { DB: D1Database } }
const { env } = Astro.props as Props;
let stats: any = { invoices: 0, products: 0, customers: 0, revenue: 0, recentInvoices: [] };
try {
  const [revR, prodR, custR, invR] = await Promise.all([
    env.DB.prepare("SELECT COUNT(*) as c, SUM(total) as t FROM invoices WHERE status='paid'").first(),
    env.DB.prepare("SELECT COUNT(*) as c FROM products").first(),
    env.DB.prepare("SELECT COUNT(*) as c FROM customers").first(),
    env.DB.prepare("SELECT i.id, i.invoice_no, i.total, i.status, i.created_at, c.name FROM invoices i LEFT JOIN customers c ON i.customer_id=c.id ORDER BY i.created_at DESC LIMIT 5").all(),
  ]);
  stats.invoices = revR?.c || 0;
  stats.revenue  = revR?.t || 0;
  stats.products = prodR?.c || 0;
  stats.customers= custR?.c || 0;
  stats.recentInvoices = invR?.results || [];
} catch(e) {}
const fmt = (n) => "$"+Number(n||0).toFixed(2);
const fmtD = (ts) => ts ? new Date(ts*1000).toLocaleDateString("en-US",{month:"short",day:"numeric"}):"—";
const pill: Record<string,string> = { draft:"pill-draft", sent:"pill-sent", paid:"pill-paid", cancelled:"pill-cancelled" };
---
<BaseLayout title="Dashboard — eTouchPOS" activeNav="">
  <div class="page-header"><h2>Dashboard</h2></div>
  <div class="stats-row">
    <div class="stat-card"><div class="stat-label">Revenue</div><div class="stat-value">{fmt(stats.revenue)}</div><div class="stat-sub">Paid invoices</div></div>
    <div class="stat-card"><div class="stat-label">Invoices</div><div class="stat-value">{stats.invoices}</div><div class="stat-sub">Paid</div></div>
    <div class="stat-card"><div class="stat-label">Products</div><div class="stat-value">{stats.products}</div><div class="stat-sub">In inventory</div></div>
    <div class="stat-card"><div class="stat-label">Customers</div><div class="stat-value">{stats.customers}</div><div class="stat-sub">Registered</div></div>
  </div>
  <div class="card">
    <div class="card-header">Recent Invoices</div>
    {stats.recentInvoices.length === 0 ? (
      <div class="card-body text-center" style="padding:2.5rem;color:var(--muted)">
        <div class="empty-icon">F</div>
        <div style="font-weight:700;margin-bottom:.5rem">No invoices yet</div>
        <a href="/invoices/new" class="btn btn-primary" style="margin-top:.5rem">+ Create First Invoice</a>
      </div>
    ) : (
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead><tr><th>Invoice</th><th>Customer</th><th class="text-right">Total</th><th>Status</th><th>Date</th><th></th></tr></thead>
          <tbody>
            {stats.recentInvoices.map((inv) => (
              <tr>
                <td><span style="font-weight:700;color:var(--navy);font-family:monospace">{inv.invoice_no}</span></td>
                <td>{inv.name||"—"}</td>
                <td class="text-right font-bold">{fmt(inv.total)}</td>
                <td><span class={"status-pill "+pill[inv.status]}>{inv.status}</span></td>
                <td class="text-muted">{fmtD(inv.created_at)}</td>
                <td><a href={"/invoices/"+inv.id} class="btn btn-secondary btn-sm">View</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1.5rem">
    <a href="/invoices/new" class="btn btn-primary btn-lg" style="justify-content:center;padding:1.5rem">
      <span style="font-size:1.5rem">+</span>
      <div><div style="font-weight:800">New Invoice</div><div style="font-size:.8rem;opacity:.8;font-weight:400">Create customer invoice</div></div>
    </a>
    <a href="/inventory/new" class="btn btn-secondary btn-lg" style="justify-content:center;padding:1.5rem;border:2px solid var(--navy)">
      <span style="font-size:1.5rem">+</span>
      <div><div style="font-weight:800">Add Product</div><div style="font-size:.8rem;opacity:.7;font-weight:400">Add item to inventory</div></div>
    </a>
  </div>
</BaseLayout>
