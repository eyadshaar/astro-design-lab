---
const stack = [
  {
    category: "Endpoint Protection",
    items: ["SentinelOne EDR", "Microsoft Defender for Business", "Webroot DNS Filtering"],
    desc: "Multi-layered endpoint defense with AI-powered threat detection and rollback capabilities."
  },
  {
    category: "Email & Collaboration",
    items: ["Microsoft 365 Defender", "Proofpoint Email Gateway", "KnowBe4 Security Training"],
    desc: "Block phishing, protect sensitive data, and train users — the human firewall approach."
  },
  {
    category: "Network Security",
    items: ["Fortinet Next-Gen Firewall", "Cisco Meraki MX", "Darktrace Network AI"],
    desc: "Perimeter defense with anomaly detection that learns your network's normal behavior."
  },
  {
    category: "Identity & Access",
    items: ["Microsoft Entra ID", "Duo Security MFA", "Savvy Security Platform"],
    desc: "Zero-trust identity management — verify everything, trust nothing, log everything."
  },
  {
    category: "Cloud Security",
    items: ["Microsoft Defender for Cloud", "Wiz.io", "Splunk Cloud"],
    desc: "Continuous compliance monitoring across Azure, M365, and AWS environments."
  },
  {
    category: "Backup & Recovery",
    items: ["Datto SaaS Protection", "Veeam Backup", "Offsite tape archiving"],
    desc: "Immutable, tested backups with verified recovery — because ransomware can't encrypt what you control."
  }
];

const phoneNumber = "(503) 555-0142";
---

<section class="security section" id="security">
  <div class="container">
    <div class="section-header reveal">
      <span class="tag">Security Stack</span>
      <h2><span class="gradient-text">Enterprise-Grade Tools.</span><br />Portland-Priced.</h2>
      <p>We partner with the industry's best — not the vendor who pays us the most — to build your security posture.</p>
      <div class="divider"></div>
    </div>

    <div class="stack-grid stagger">
      {stack.map(item => (
        <div class="stack-card card reveal">
          <div class="stack-category">{item.category}</div>
          <p class="stack-desc">{item.desc}</p>
          <div class="stack-items">
            {item.items.map(product => (
              <span class="stack-product">{product}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="security-cta">
      <div class="security-note">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
        </svg>
        <p>We don't mark up software licenses — our margins are in our service, not your subscriptions.</p>
      </div>
      <a href="tel:+150****0142" class="btn btn-primary">Get a Security Assessment — (503) 555-0142</a>
    </div>
  </div>
</section>

<style>
  .security {
    background: var(--white);
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .stack-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border-top: 3px solid var(--amber);
    transition: all 0.4s var(--ease-spring);
  }

  .stack-category {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 800;
    color: var(--slate);
  }

  .stack-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
  }

  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-sm);
  }

  .stack-product {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--white);
    background: var(--slate);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .security-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding: var(--space-lg);
    background: var(--warm-gray);
    border-radius: var(--radius-lg);
  }

  .security-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    color: var(--text-muted);
  }

  .security-note svg {
    color: var(--amber);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .security-note p {
    font-size: 0.9rem;
    max-width: 50ch;
  }

  @media (max-width: 900px) {
    .stack-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .security-cta {
      flex-direction: column;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>