---
const timeline = [
  {
    time: "0–15 min",
    phase: "Alert & Acknowledge",
    desc: "Our SIEM detects anomaly. Ticket opened. On-call engineer alerted via Slack + SMS simultaneously.",
    status: "automated"
  },
  {
    time: "15–30 min",
    phase: "Triage & Contain",
    desc: "Engineer validates threat, isolates affected endpoint, and engages containment playbooks — no waiting for a ticket response.",
    status: "human"
  },
  {
    time: "30–60 min",
    phase: "Eradicate & Remediate",
    desc: "Malware removed, credentials rotated, patches deployed. Full forensic snapshot taken for post-incident review.",
    status: "human"
  },
  {
    time: "1–4 hrs",
    phase: "Recover & Verify",
    desc: "Systems restored from clean backup. Verification checks run end-to-end. Customer informed with full incident summary.",
    status: "verified"
  }
];

const phoneNumber = "(503) 555-0142";
---

<section class="response section" id="response">
  <div class="container">
    <div class="section-header reveal">
      <span class="tag">Incident Response</span>
      <h2>From Alert to Resolution<br /><span class="gradient-text">in Under 4 Hours</span></h2>
      <p>While others promise "24/7 support," we prove it with a documented 4-hour SLA — backed by our guarantee.</p>
      <div class="divider"></div>
    </div>

    <div class="timeline stagger">
      {timeline.map((item, i) => (
        <div class="timeline-item">
          <div class="timeline-connector">
            <div class="timeline-node"></div>
            {i < timeline.length - 1 && <div class="timeline-line"></div>}
          </div>
          <div class="timeline-content card">
            <div class="timeline-time">{item.time}</div>
            <div class="timeline-phase">{item.phase}</div>
            <p class="timeline-desc">{item.desc}</p>
            <span class={`timeline-badge badge-${item.status}`}>{item.status}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="response-cta">
      <div class="response-guarantee">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <div>
          <strong>4-Hour Response Guarantee</strong>
          <p>Any critical-priority ticket acknowledged within 4 hours — or your month is free.</p>
        </div>
      </div>
      <a href="tel:+150****0142" class="btn btn-primary">Call (503) 555-0142</a>
    </div>
  </div>
</section>

<style>
  .response {
    background: var(--slate-dark);
    position: relative;
    overflow: hidden;
  }

  .response::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(184, 122, 58, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(184, 122, 58, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    -webkit-mask-image: linear-gradient(to bottom, #000 70%, transparent 100%);
            mask-image: linear-gradient(to bottom, #000 70%, transparent 100%);
    pointer-events: none;
  }

  .response .tag { color: var(--amber); border-color: var(--amber); }
  .response h2 { color: var(--white); }
  .response .section-header p { color: rgba(255,255,255,0.6); }

  .timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-2xl);
  }

  .timeline-item {
    display: flex;
    gap: var(--space-md);
  }

  .timeline-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 24px;
  }

  .timeline-node {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--amber);
    border: 4px solid var(--slate-dark);
    box-shadow: 0 0 0 3px rgba(184, 122, 58, 0.3);
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-line {
    flex: 1;
    width: 3px;
    background: linear-gradient(to bottom, var(--amber), rgba(184, 122, 58, 0.3));
    min-height: 40px;
  }

  .timeline-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    background: var(--slate);
    border-color: rgba(184, 122, 58, 0.2);
    transition: all 0.4s var(--ease-spring);
  }

  .timeline-time {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-phase {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--white);
  }

  .timeline-desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    flex-grow: 1;
  }

  .timeline-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .badge-automated { background: rgba(34, 197, 94, 0.2); color: var(--green-ok); }
  .badge-human     { background: rgba(184, 122, 58, 0.2);  color: var(--amber); }
  .badge-verified  { background: rgba(96, 165, 250, 0.2); color: #60A5FA; }

  /* CTA */
  .response-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    padding: var(--space-xl);
    background: rgba(184, 122, 58, 0.08);
    border: 2px solid rgba(184, 122, 58, 0.3);
    border-radius: var(--radius-lg);
    position: relative;
    z-index: 1;
  }

  .response-guarantee {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .response-guarantee svg {
    flex-shrink: 0;
  }

  .response-guarantee strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 4px;
  }

  .response-guarantee p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    max-width: 50ch;
  }

  @media (max-width: 900px) {
    .timeline {
      grid-template-columns: 1fr;
    }

    .timeline-connector {
      display: none;
    }

    .response-cta {
      flex-direction: column;
      text-align: center;
    }
  }
</style>