---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fieldstone IT — Managed IT & Cybersecurity | Portland, OR",
  description = "Portland's trusted managed IT services provider. 24/7 monitoring, cybersecurity, and cloud solutions for local businesses. Call (503) 555-0142."
} = Astro.props;

const phoneNumber = "(503) 555-0142";
const phoneHref = "tel:+15035550142";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <script>
      // Reveal observer — uses both 'visible' and 'is-visible' classes for backward compat
      const observer = new IntersectionObserver(
        e => e.forEach(el => {
          if (el.isIntersecting) {
            el.target.classList.add('is-visible');
            el.target.classList.add('visible');
          }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>

<style>
  /* Ensure full-width sections don't bleed */
  :global(body > *) {
    width: 100%;
  }
</style>