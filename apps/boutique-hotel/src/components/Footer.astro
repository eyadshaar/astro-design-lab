---
// Footer.astro
---
<footer class="footer">
  <div class="footer__top">
    <div class="footer__brand">
      <span class="footer__logo-mark">&#10022;</span>
      <span class="footer__logo-text">The Canopy House</span>
      <p class="footer__tagline">
        Old-growth forest, Pacific Northwest.<br />
        Twelve rooms. Unhurried since 2018.
      </p>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h4 class="footer__col-head">Navigate</h4>
        <nav class="footer__nav">
          <a href="#rooms">Rooms</a>
          <a href="#philosophy">Philosophy</a>
          <a href="#guide">Local Guide</a>
          <a href="#gallery">Gallery</a>
        </nav>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-head">Contact</h4>
        <div class="footer__info">
          <p>Old Growth District<br />Oregon 97463</p>
          <a href="mailto:stay@thecanopyhouse.com">stay@thecanopyhouse.com</a>
        </div>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-head">Find</h4>
        <div class="footer__info">
          <a href="#">Instagram</a>
          <a href="#">Newsletter</a>
          <a href="#">Press</a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <p class="footer__copy">
      &copy; 2025 The Canopy House. All rights reserved.
    </p>
    <p class="footer__credit">
      <span class="ornament">&#10022;</span>
      Forest Journal aesthetic by Canopy Studio, Oregon
    </p>
  </div>
</footer>

<style>
.footer {
  background: var(--ink);
  color: rgba(248,245,240,0.6);
  padding: var(--space-xl) 0 var(--space-md);
}

.footer__top {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem 4rem;
  display: grid;
  grid-template-columns: 1.4fr 1.6fr;
  gap: 4rem;
  border-bottom: 1px solid rgba(248,245,240,0.08);
}

.footer__logo-mark {
  display: block;
  color: var(--amber);
  font-size: 1rem;
  margin-bottom: 0.75rem;
}

.footer__logo-text {
  display: block;
  font-family: var(--serif);
  font-size: 1.4rem;
  color: var(--cream);
  margin-bottom: 1.2rem;
}

.footer__tagline {
  font-size: 0.85rem;
  line-height: 1.7;
  font-style: italic;
  color: rgba(248,245,240,0.5);
}

.footer__cols {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.footer__col-head {
  font-family: var(--sans);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 1.2rem;
}

.footer__nav {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.footer__nav a {
  font-size: 0.85rem;
  color: rgba(248,245,240,0.55);
  transition: color 0.25s ease;
}

.footer__nav a:hover {
  color: var(--cream);
}

.footer__info {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.footer__info p,
.footer__info a {
  font-size: 0.85rem;
  color: rgba(248,245,240,0.55);
  transition: color 0.25s ease;
  line-height: 1.5;
}

.footer__info a:hover {
  color: var(--cream);
}

.footer__bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 2rem 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer__copy {
  font-size: 0.75rem;
  color: rgba(248,245,240,0.3);
}

.footer__credit {
  font-size: 0.7rem;
  color: rgba(248,245,240,0.25);
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.footer__credit .ornament {
  font-size: 0.6rem;
}

@media (max-width: 1024px) {
  .footer__top {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}

@media (max-width: 640px) {
  .footer__cols {
    grid-template-columns: 1fr 1fr;
  }

  .footer__bottom {
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }
}
</style>