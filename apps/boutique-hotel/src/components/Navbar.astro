---
// Navbar.astro — Forest journal editorial navigation
---
<header class="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">
      <span class="navbar__logo-mark">&#10022;</span>
      <span class="navbar__logo-text">The Canopy House</span>
    </a>

    <nav class="navbar__nav">
      <a href="#rooms" class="navbar__link">Rooms</a>
      <a href="#philosophy" class="navbar__link">Philosophy</a>
      <a href="#guide" class="navbar__link">Local Guide</a>
      <a href="#gallery" class="navbar__link">Gallery</a>
      <a href="#reserve" class="navbar__link navbar__link--cta">Reserve</a>
    </nav>

    <button class="navbar__toggle" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
/* ── Easing ── */
.navbar {
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ── Navbar ── */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 1.5rem 0;
  transition:
    background 0.4s var(--ease-out),
    padding 0.4s var(--ease-out),
    box-shadow 0.4s var(--ease-out);
}

.navbar.scrolled {
  background: rgba(248, 245, 240, 0.94);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 1rem 0;
  box-shadow: 0 1px 0 rgba(74, 93, 74, 0.08);
}

.navbar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 2rem;
}

.navbar__logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.navbar__logo-mark {
  color: var(--amber);
  font-size: 1.1rem;
}

.navbar__logo-text {
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 400;
  letter-spacing: 0.02em;
  color: var(--cream);
  transition: color 0.4s var(--ease-out);
}

.navbar.scrolled .navbar__logo-text {
  color: var(--ink);
}

.navbar__nav {
  display: flex;
  align-items: center;
  gap: 2.5rem;
}

.navbar__link {
  font-family: var(--sans);
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(248, 245, 240, 0.8);
  padding: 0.5rem 0.75rem;
  border-radius: 4px;
  transition:
    color 0.25s var(--ease-out),
    background-color 0.25s var(--ease-out),
    box-shadow 0.25s var(--ease-out),
    transform 0.35s var(--ease-spring);
}

.navbar__link:hover {
  color: var(--cream);
  background-color: rgba(248, 245, 240, 0.08);
  box-shadow: inset 0 0 0 0.7px rgba(248, 245, 240, 0.15);
  transform: translateY(-1px);
}

.navbar__link--cta {
  padding: 0.6rem 1.5rem;
  border: 1px solid rgba(248, 245, 240, 0.4);
  border-radius: 2px;
  transition:
    color 0.3s var(--ease-out),
    background-color 0.3s var(--ease-out),
    border-color 0.3s var(--ease-out),
    transform 0.35s var(--ease-spring),
    box-shadow 0.35s var(--ease-spring);
}

.navbar__link--cta:hover {
  background: var(--cream);
  color: var(--ink);
  border-color: var(--cream);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

.navbar.scrolled .navbar__link {
  color: rgba(28, 28, 26, 0.65);
  transition:
    color 0.25s var(--ease-out),
    background-color 0.25s var(--ease-out),
    box-shadow 0.25s var(--ease-out),
    transform 0.35s var(--ease-spring);
}
.navbar.scrolled .navbar__link:hover {
  color: var(--ink);
  background-color: rgba(74, 93, 74, 0.06);
  box-shadow: inset 0 0 0 0.7px rgba(74, 93, 74, 0.12);
  transform: translateY(-1px);
}
.navbar.scrolled .navbar__link--cta {
  border-color: var(--green);
  color: var(--green);
  transition:
    color 0.3s var(--ease-out),
    background-color 0.3s var(--ease-out),
    border-color 0.3s var(--ease-out),
    transform 0.35s var(--ease-spring),
    box-shadow 0.35s var(--ease-spring);
}
.navbar.scrolled .navbar__link--cta:hover {
  background: var(--green);
  color: var(--cream);
  border-color: var(--green);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(53, 66, 53, 0.25);
}

.navbar__toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 4px;
}

.navbar__toggle span {
  display: block;
  width: 22px;
  height: 1.5px;
  background: var(--cream);
  transition: background 0.3s ease;
}

.navbar.scrolled .navbar__toggle span {
  background: var(--ink);
}

@media (max-width: 768px) {
  .navbar__nav {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--green-dark);
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
  }

  .navbar__nav.open {
    display: flex;
  }

  .navbar__link {
    font-size: 0.85rem;
    color: var(--cream);
  }

  .navbar__toggle {
    display: flex;
  }
}
</style>

<script>
const navbar = document.querySelector('.navbar');
const toggle = document.querySelector('.navbar__toggle');
const nav = document.querySelector('.navbar__nav');

window.addEventListener('scroll', () => {
  navbar?.classList.toggle('scrolled', window.scrollY > 60);
});

toggle?.addEventListener('click', () => {
  nav?.classList.toggle('open');
});
</script>