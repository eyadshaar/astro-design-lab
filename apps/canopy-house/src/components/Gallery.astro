---
const images = [
  { src: '/images/gallery-morning-mist.jpg',   alt: 'Morning mist over old-growth forest' },
  { src: '/images/gallery-cedar-beams.jpg',     alt: 'Hand-hewn cedar beams in the Forest Suite' },
  { src: '/images/gallery-garden-path.jpg',      alt: 'Garden path at dusk' },
  { src: '/images/gallery-coast-sunset.jpg',   alt: 'Pacific coast sunset from Rialto Beach' },
  { src: '/images/gallery-pastries.jpg',        alt: 'Fresh pastries from the kitchen' },
  { src: '/images/gallery-sauna.jpg',           alt: 'Cedar sauna at sunset' },
];
---

<section class="gallery reveal" id="gallery">
  <div class="gallery__header-wrap">
    <div class="container">
      <div class="gallery__header">
        <span class="eyebrow">The Property</span>
        <h2 class="gallery__title">Glimpses of the Forest</h2>
      </div>
    </div>
  </div>
  <div class="gallery__strip">
    {images.map((img, i) => (
      <figure class="gallery__item" aria-label={img.alt}>
        <img src={img.src} alt={img.alt} class="gallery__img" loading="lazy" />
      </figure>
    ))}
  </div>
</section>

<style>
  .gallery {
    background: var(--cream);
    overflow: hidden;
  }

  .gallery__header-wrap {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .gallery__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .gallery__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
  }

  .gallery__strip {
    display: flex;
    gap: var(--space-sm);
    overflow-x: auto;
    padding: 0 var(--space-lg) var(--space-2xl);
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* Mask fades on edges */
    -webkit-mask-image: linear-gradient(to right, transparent 0px, black 48px, black calc(100% - 48px), transparent 100%);
            mask-image: linear-gradient(to right, transparent 0px, black 48px, black calc(100% - 48px), transparent 100%);
  }

  .gallery__strip::-webkit-scrollbar { height: 4px; }
  .gallery__strip::-webkit-scrollbar-thumb { background: var(--amber); border-radius: 2px; }

  .gallery__item {
    flex: 0 0 340px;
    height: 240px;
    border-radius: var(--radius-md);
    overflow: hidden;
    scroll-snap-align: start;
    background: var(--forest-dim);
  }

  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .gallery__item:hover .gallery__img {
    transform: scale(1.06);
  }
</style>