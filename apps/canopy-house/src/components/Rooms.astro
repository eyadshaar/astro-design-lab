---
const roomList = [
  {
    name: 'Forest Suite',
    size: '680 sq ft',
    view: 'Old-growth canopy',
    description: 'Hand-hewn beams, a private balcony, and morning mist visible from your bed.',
    img: '/images/room-forest-suite.jpg',
    alt: 'Forest Suite interior with hand-hewn timber beams and forest view',
  },
  {
    name: 'Cedar Room',
    size: '420 sq ft',
    view: 'Garden courtyard',
    description: 'Clawfoot soaking tub surrounded by cedar paneling and native ferns.',
    img: '/images/room-cedar-room.jpg',
    alt: 'Cedar Room with clawfoot soaking tub and cedar paneling',
  },
  {
    name: 'The Loft',
    size: '540 sq ft',
    view: 'Three-floor living',
    description: 'Two levels connected by a ship ladder, ideal for longer stays.',
    img: '/images/room-loft.jpg',
    alt: 'The Loft bedroom with exposed beams and ship ladder access',
  },
];
---

<section class="rooms" id="rooms">
  <div class="rooms__intro reveal">
    <div class="rooms__intro-inner">
      <span class="eyebrow">Accommodations</span>
      <h2 class="rooms__title">Three Rooms,<br />One Forest</h2>
    </div>
  </div>

  <div class="rooms__spread">
    {roomList.map((room, i) => (
      <article class="room-card" style={`--i: ${i}`}>
        <div class="room-card__visual">
          <img src={room.img} alt={room.alt} class="room-card__img" loading="lazy" />
          <div class="room-card__index" aria-hidden="true">0{i + 1}</div>
        </div>
        <div class="room-card__body">
          <div class="room-card__meta">
            <span class="room-card__size">{room.size}</span>
            <span class="room-card__sep">·</span>
            <span class="room-card__view">{room.view}</span>
          </div>
          <h3 class="room-card__name">{room.name}</h3>
          <p class="room-card__desc">{room.description}</p>
          <a href="#reserve" class="room-card__link">
            Inquire
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .rooms {
    background: var(--cream);
    padding: var(--space-3xl) 0;
  }

  .rooms__intro {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .rooms__intro-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 480px;
  }

  .rooms__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--charcoal);
    line-height: 1.1;
  }

  .rooms__spread {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    padding: 0 var(--space-lg);
    max-width: 1200px;
    margin: 0 auto;
  }

  .room-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .room-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(45, 42, 38, 0.14);
  }

  .room-card__visual {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--forest-dim);
  }

  .room-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .room-card:hover .room-card__img {
    transform: scale(1.05);
  }

  .room-card__index {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 300;
    color: rgba(248,245,240,0.8);
    line-height: 1;
    pointer-events: none;
  }

  .room-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
    border-top: 1px solid var(--amber);
    transition: border-left 0.3s ease, padding-left 0.3s ease;
  }

  .room-card:hover .room-card__body {
    border-left: 2px solid var(--amber);
    padding-left: calc(var(--space-lg) + 2px);
  }

  .room-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--forest);
    opacity: 0.75;
  }

  .room-card__sep { opacity: 0.5; }

  .room-card__name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1.2;
  }

  .room-card__desc {
    font-size: 0.9375rem;
    color: rgba(45, 42, 38, 0.7);
    line-height: 1.6;
    flex: 1;
  }

  .room-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--forest);
    transition: gap 0.2s ease;
  }

  .room-card__link:hover { gap: 0.7rem; }

  .room-card__link {
    transition: gap 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.3s;
  }

  .room-card__link:hover { color: var(--amber); }

  .room-card__link svg {
    transition: transform 0.2s ease;
  }

  .room-card__link:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .rooms__spread {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }
</style>