---
const phoneNumber = "419 345 7778";
const phoneHref = "tel:+14193457778";
const address = "1030 N Holland Sylvania Toledo OH 43615";
const email = "info@glisohio.com";
---

<section class="contact section" id="contact">
  <div class="container">
    <div class="contact-layout">
      <!-- Left: Info -->
      <div class="contact-info">
        <div class="section-header reveal" style="text-align:left">
          <span class="tag">Contact Us</span>
          <h2><span class="gradient-text">Let's Talk Coverage</span></h2>
          <p>Whether you're switching from another carrier or getting coverage for the first time, we'll find the right policy for you — at the right price.</p>
          <div class="divider" style="margin:1rem 0 0"></div>
        </div>

        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Phone</div>
              <a href={phoneHref} class="contact-value phone-link">{phoneNumber}</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Email</div>
              <a href={`mailto:${email}`} class="contact-value">{email}</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Office</div>
              <span class="contact-value">{address}</span>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Hours</div>
              <span class="contact-value">Mon–Fri 8am–6pm / Sat 9am–1pm</span>
            </div>
          </div>
        </div>

        <a href={phoneHref} class="btn btn-primary contact-phone-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          Call 419 345 7778
        </a>
      </div>

      <!-- Right: Map -->
      <div class="contact-map">
        <div class="map-wrapper">
          <div class="map-placeholder">
            <div class="map-overlay">
              <div class="map-pin">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="var(--navy)" stroke="var(--white)" stroke-width="1.5">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div class="map-info">
                <strong>Great Lakes Insurance Solutions</strong>
                <span>1030 N Holland Sylvania</span>
                <span>Toledo, OH 43615</span>
                <span class="map-note">Serving Ohio families</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--white);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    background: rgba(196, 154, 44, 0.08);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--navy);
  }

  .contact-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 2px;
  }

  .contact-value {
    font-size: 1rem;
    color: var(--navy);
    font-weight: 600;
    transition: color 0.4s var(--ease-spring);
  }

  .phone-link {
    transition: all 0.4s var(--ease-spring);
  }

  .contact-phone-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1.05rem;
  }

  .map-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 3px solid var(--stone-warm);
    aspect-ratio: 4/3;
    -webkit-mask-image: linear-gradient(to bottom, #000 90%, transparent 100%);
            mask-image: linear-gradient(to bottom, #000 90%, transparent 100%);
  }

  .map-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl);
    color: var(--white);
    text-align: center;
  }

  .map-pin {
    animation: bounce-pin 2s infinite;
  }

  @keyframes bounce-pin {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .map-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .map-info strong {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
  }

  .map-info span {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
  }

  .map-note {
    margin-top: var(--space-sm);
    font-size: 0.8rem !important;
    color: var(--navy) !important;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-map { order: -1; }
  }
</style>