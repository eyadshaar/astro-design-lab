---
const plans = [
  {
    name: "Essential",
    price: "$149",
    unit: "/user/month",
    tagline: "Core IT coverage for small teams",
    features: [
      "Unlimited helpdesk tickets",
      "Remote monitoring & patching",
      "Microsoft 365 management",
      "99.9% uptime SLA",
      "Quarterly business review",
      "Email support (next-business-day)",
      "Per-user pricing, minimum 5 users"
    ],
    cta: "Get Started",
    highlight: false
  },
  {
    name: "Professional",
    price: "$249",
    unit: "/user/month",
    tagline: "Full managed IT with security",
    features: [
      "Everything in Essential, plus:",
      "SentinelOne EDR endpoint protection",
      "Darktrace Network AI monitoring",
      "Microsoft 365 Defender management",
      "Email phishing simulation (KnowBe4)",
      "4-hour critical response SLA",
      "Monthly security score report",
      "Dedicated vCIO (virtual CTO)",
      "Priority on-site support option"
    ],
    cta: "Most Popular",
    highlight: true
  },
  {
    name: "Enterprise",
    price: "Custom",
    unit: "pricing",
    tagline: "Compliance-ready, full security ops",
    features: [
      "Everything in Professional, plus:",
      "HIPAA/SOC2 gap assessment support",
      "Full backup & disaster recovery (BC/DR)",
      "Veeam managed backup with testing",
      "Darktrace SIEM integration",
      "24/7 NOC monitoring with live engineers",
      "Quarterly disaster recovery testing",
      "Annual penetration testing coordination",
      "Dedicated account engineer (on-site)"
    ],
    cta: "Schedule Consultation",
    highlight: false
  }
];

const phoneNumber = "(503) 555-0142";
---

<section class="plans section" id="plans">
  <div class="container">
    <div class="section-header reveal">
      <span class="tag">Maintenance Plans</span>
      <h2><span class="gradient-text">Transparent Pricing.</span><br />No Hidden Fees.</h2>
      <p>Pick the coverage that fits your business. All plans include our 4-hour response guarantee.</p>
      <div class="divider"></div>
    </div>

    <div class="plans-grid stagger">
      {plans.map(plan => (
        <div class={`plan-card card ${plan.highlight ? 'plan-highlight' : ''} reveal`}>
          {plan.highlight && <div class="plan-badge">Most Popular</div>}
          <div class="plan-name">{plan.name}</div>
          <div class="plan-pricing">
            <span class="plan-price">{plan.price}</span>
            <span class="plan-unit">{plan.unit}</span>
          </div>
          <div class="plan-tagline">{plan.tagline}</div>
          <ul class="plan-features">
            {plan.features.map(f => <li set:html={f.startsWith('Everything') ? `<strong>${f}</strong>` : f}></li>)}
          </ul>
          <a href="tel:+150****0142" class={`btn ${plan.highlight ? 'btn-primary' : 'btn-outline'}`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="plans-note">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      <p>All plans include our <strong>4-hour response SLA</strong> on critical issues. No tiers, no extra charges.</p>
    </div>
  </div>
</section>

<style>
  .plans {
    background: var(--warm-gray);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    align-items: start;
  }

  .plan-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
    transition: all 0.4s var(--ease-spring);
  }

  .plan-highlight {
    border: 3px solid var(--amber);
    box-shadow: 0 12px 48px rgba(184, 122, 58, 0.2);
  }

  .plan-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--amber);
    color: var(--white);
    padding: 0.3rem 1rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .plan-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--slate);
    text-align: center;
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--stone-warm);
  }

  .plan-pricing {
    text-align: center;
  }

  .plan-price {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 900;
    color: var(--amber);
    line-height: 1;
  }

  .plan-unit {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-muted);
    display: block;
    margin-top: 4px;
  }

  .plan-tagline {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex-grow: 1;
  }

  .plan-features li {
    font-size: 0.9rem;
    color: var(--text-dark);
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    line-height: 1.5;
  }

  .plan-features li::before {
    content: '✓';
    color: var(--amber);
    font-weight: 700;
    flex-shrink: 0;
  }

  .plan-features li strong {
    color: var(--slate);
  }

  .plan-card .btn {
    text-align: center;
    width: 100%;
    margin-top: auto;
  }

  .plans-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: rgba(184, 122, 58, 0.06);
    border-radius: var(--radius-md);
    border: 1px solid rgba(184, 122, 58, 0.2);
  }

  .plans-note svg {
    color: var(--green-ok);
    flex-shrink: 0;
  }

  .plans-note p {
    font-size: 0.95rem;
    color: var(--text-dark);
    max-width: none;
  }

  .plans-note strong {
    color: var(--amber);
  }

  @media (max-width: 900px) {
    .plans-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }

    .plan-highlight {
      order: -1;
    }
  }
</style>