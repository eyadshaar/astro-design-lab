---
const phoneNumber = "(614) 555-0199";
const phoneHref = "tel:+161****0199";
---

<section class="claims section" id="claims">
  <div class="container">
    <div class="section-header reveal">
      <span class="tag">Claims</span>
      <h2><span class="gradient-text">When You Need Us Most</span></h2>
      <p>We hope you never need to file a claim — but if you do, we make it as painless as possible.</p>
      <div class="divider"></div>
    </div>

    <div class="claims-layout">
      <div class="claims-steps stagger">
        <div class="step-card reveal">
          <span class="step-num">1</span>
          <div class="step-content">
            <h3>Call Us Day or Night</h3>
            <p>Our claims team is available 24/7. We take the call ourselves — no robots, no wait music. We'll guide you through the first steps immediately.</p>
          </div>
        </div>

        <div class="step-card reveal">
          <span class="step-num">2</span>
          <div class="step-content">
            <h3>We Handle the Paperwork</h3>
            <p>Our team contacts your carrier, submits the forms, and follows up — so you don't have to navigate confusing insurance bureaucracy alone.</p>
          </div>
        </div>

        <div class="step-card reveal">
          <span class="step-num">3</span>
          <div class="step-content">
            <h3>Fast Resolution</h3>
            <p>98% of our claims are resolved within 14 days. We stay on top of your carrier until the check is in your hands.</p>
          </div>
        </div>
      </div>

      <div class="claims-cta reveal">
        <div class="cta-box">
          <div class="cta-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <h3>Need to File a Claim?</h3>
          <p>Call us 24/7 — we're here to help you through it.</p>
          <a href={phoneHref} class="btn btn-primary">Call (614) 555-0199</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .claims {
    background: var(--navy-dark);
    color: var(--white);
  }

  .claims-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .claims-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .step-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(196, 154, 44, 0.15);
    border-radius: var(--radius-lg);
    transition: all 0.4s var(--ease-spring);
  }

  .step-card:hover {
    background: rgba(196, 154, 44, 0.08);
    border-color: rgba(196, 154, 44, 0.3);
  }

  .step-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy-dark);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-content h3 {
    color: var(--white);
    font-size: 1.15rem;
    margin-bottom: var(--space-xs);
  }

  .step-content p {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: none;
  }

  .cta-box {
    background: var(--navy);
    border: 2px solid rgba(196, 154, 44, 0.4);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .cta-icon { margin-bottom: var(--space-sm); }

  .cta-box h3 {
    color: var(--white);
    font-size: 1.5rem;
  }

  .cta-box p {
    color: rgba(255,255,255,0.6);
    max-width: 32ch;
  }

  @media (max-width: 900px) {
    .claims-layout { grid-template-columns: 1fr; }
  }
</style>