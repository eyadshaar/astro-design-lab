---
const phoneNumber = "419 345 7778";
const phoneHref = "tel:+141****7778";
const businessName = "Great Lakes Insurance Solutions";
---

<header class="navbar">
  <div class="container navbar-inner">
    <!-- Logo -->
    <a href="/" class="logo">
      <span class="logo-icon">
        <img src="/logo.jpg" alt="Great Lakes Insurance Solutions Logo" width="40" height="40" style="border-radius: 6px; object-fit: contain;" />
      </span>
      <span class="logo-text">{businessName}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="nav-links">
      <a href="#products">Products</a>
      <a href="#claims">Claims</a>
      <a href="#about">About</a>
      <a href="#reviews">Reviews</a>
      <a href="#contact">Contact</a>
    </nav>

    <!-- Phone CTA -->
    <div class="nav-phone">
      <span class="nav-phone-label">Free Quote</span>
      <a href={phoneHref} class="nav-phone-number">{phoneNumber}</a>
    </div>

    <!-- Mobile menu button -->
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile Nav Drawer -->
  <div class="mobile-nav" id="mobileNav">
    <nav>
      <a href="#products" class="mobile-nav-link">Products</a>
      <a href="#claims" class="mobile-nav-link">Claims</a>
      <a href="#about" class="mobile-nav-link">About</a>
      <a href="#reviews" class="mobile-nav-link">Reviews</a>
      <a href="#contact" class="mobile-nav-link">Contact</a>
    </nav>
    <a href={phoneHref} class="mobile-phone-cta">{phoneNumber}</a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--silver-bright);
    border-bottom: 3px solid var(--navy);
    box-shadow:
      0 4px 24px rgba(15, 30, 58, 0.15),
      inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    gap: var(--space-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--white);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.3rem;
    letter-spacing: -0.02em;
    color: var(--navy-dark);
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--navy-dark);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0;
    transition: color 0.3s ease;
  }
  .nav-links a:hover { color: var(--navy); }

  .nav-phone {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .nav-phone-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--navy);
  }

  .nav-phone-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--navy);
    text-decoration: none;
    line-height: 1;
    transition: color 0.3s ease;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  .nav-phone-number:hover { color: var(--navy-mid); }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .mobile-menu-btn span {
    display: block;
    width: 100%;
    height: 3px;
    background: var(--navy-dark);
    border-radius: 2px;
    transition: all 0.4s var(--ease-spring);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--navy-dark);
    padding: var(--space-lg);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .mobile-nav.open { display: flex; }

  .mobile-nav nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .mobile-nav-link {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--navy-dark);
    text-decoration: none;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(30, 58, 110, 0.15);
    transition: color 0.4s var(--ease-spring);
  }

  .mobile-nav-link:hover { color: var(--navy); }

  .mobile-phone-cta {
    margin-top: var(--space-lg);
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--navy);
    text-align: center;
    text-decoration: none;
    padding: var(--space-md);
    background: rgba(30, 58, 110, 0.06);
    border-radius: var(--radius-md);
    border: 2px solid var(--navy);
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }

  @media (max-width: 768px) {
    .nav-links, .nav-phone { display: none; }
    .mobile-menu-btn { display: flex; }
  }
</style>

<script>
  const btn = document.getElementById('mobileMenuBtn');
  const nav = document.getElementById('mobileNav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      nav.classList.toggle('open');
    });
    nav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => nav.classList.remove('open'));
    });
  }
</script>
