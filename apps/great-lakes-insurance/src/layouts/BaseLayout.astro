---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Great Lakes Insurance — Ohio's Trusted Independent Agency | Columbus, OH",
  description = "Great Lakes Insurance protects Ohio families and businesses with home, auto, business, and life insurance. Independent agents, 20+ carriers, 98% claims satisfaction. Call (614) 555-0199."
} = Astro.props;

const phoneNumber = "(614) 555-0199";
const phoneHref = "tel:+161****0199";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <script>
      const observer = new IntersectionObserver(
        e => e.forEach(el => {
          if (el.isIntersecting) {
            el.target.classList.add('is-visible');
            el.target.classList.add('visible');
          }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>

<style>
  :global(body > *) {
    width: 100%;
  }
</style>