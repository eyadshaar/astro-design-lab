---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Great Lakes Insurance Solutions — Toledo, OH",
    description = "Great Lakes Insurance Solutions provides personalized coverage for homes, autos, and businesses in Ohio. Independent agents, 20+ carriers. Call (419) 345-7778."
} = Astro.props;

const phoneNumber = "419 345 7778";
const phoneHref = "tel:+141****7778";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
  </head>
  <body>
    <slot />
    <script>
      const observer = new IntersectionObserver(
        e => e.forEach(el => {
          if (el.isIntersecting) {
            el.target.classList.add('is-visible');
            el.target.classList.add('visible');
          }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>

<style>
  :global(body > *) {
    width: 100%;
  }
</style>